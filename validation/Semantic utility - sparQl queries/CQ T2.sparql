# ============================================================
# CQ T2 — Sensor Alarm Propagation
# ============================================================
# Definition: Determine whether a sensor-level technical alarm
# propagates to multiple downstream metrics.
# This tests whether the ontology captures technical dependency
# structure in the measurement chain.
#
# Input:  A sensor individual (e.g. inst:Pulse_Oximeter_Sensor)
# Output: The alarms triggered by a fault on that sensor, and
#         all metrics those alarms implicitly invalidate
#
# Traversal path:
#   ACD → requiresCondition → Condition → aboutEntity → Sensor
#       ← isProducedBy ← Signal → inputToProcess
#       → MeasurementProcess → producesMetric → Metric
#
# Two variants:
#   T2a — Parametric : given a specific sensor, list affected alarms + metrics
#   T2b — Discovery  : list every alarm whose sensor fans out to > 1 metric
# ============================================================

PREFIX dev:    <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#>
PREFIX common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#>
PREFIX clin:   <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#>
PREFIX inst:   <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>


# ------------------------------------------------------------
# T2a — Parametric: given a sensor, find its alarms and affected metrics
# ------------------------------------------------------------
# Replace inst:Pulse_Oximeter_Sensor with any sensor individual.
# ------------------------------------------------------------

SELECT ?alarmLabel ?metric ?metricLabel WHERE {

  # --- Bind your target sensor here ---
  BIND(inst:Pulse_Oximeter_Sensor AS ?sensor)

  # Step 1: find alarms whose condition is about this sensor
  ?acd a dev:AlertConditionDescription ;
       dev:alarmMessageLabel ?alarmLabel ;
       dev:requiresCondition ?cond .

  ?cond dev:aboutEntity ?sensor .

  # Step 2: follow sensor → signal → process → metric
  ?signal dev:isProducedBy ?sensor ;
          dev:inputToProcess ?process .

  ?process dev:producesMetric ?metric .

  OPTIONAL { ?metric dev:hasLabel ?metricLabel }
}
ORDER BY ?alarmLabel ?metricLabel


# ------------------------------------------------------------
# T2b — Discovery: alarms whose sensor invalidates MULTIPLE metrics
# ------------------------------------------------------------
# No input. Returns every alarm label where the underlying sensor
# fans out to more than one downstream metric.
# Alarms tied to single-metric sensors are excluded (HAVING).
# ------------------------------------------------------------

PREFIX dev:    <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#>
PREFIX common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#>
PREFIX clin:   <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#>
PREFIX inst:   <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?alarmLabel
       (COUNT(DISTINCT ?metric) AS ?affectedMetricCount)
       (GROUP_CONCAT(DISTINCT ?metricLabel ; separator=", ") AS ?affectedMetrics)
WHERE {

  # Step 1: find alarms whose condition is about a sensor
  ?acd a dev:AlertConditionDescription ;
       dev:alarmMessageLabel ?alarmLabel ;
       dev:requiresCondition ?cond .

  ?cond dev:aboutEntity ?sensor .

  # Step 2: follow sensor → signal → process → metric
  ?signal dev:isProducedBy ?sensor ;
          dev:inputToProcess ?process .

  ?process dev:producesMetric ?metric .

  OPTIONAL { ?metric dev:hasLabel ?metricLabel }
}
GROUP BY ?alarmLabel
HAVING (COUNT(DISTINCT ?metric) > 1)
ORDER BY DESC(?affectedMetricCount) ?alarmLabel

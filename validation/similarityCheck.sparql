# Detect groups of alarms with IDENTICAL condition sets.
#
# Each alarm is assigned a canonical representative = the lexicographically
# minimum equivalent alarm IRI. Alarms sharing the same canonical form one group.
#
# Conditions matched by IRI identity (e.g. :Cond_PhilipsMonitor_FunctionalState_Enabled),
# not by (aboutEntity, onAttribute, hasValue) triples.
#
# Notes:
#   - STR(?alarm1) < STR(?alarm2) is required: plain < on IRIs is undefined in SPARQL
#     and silently returns false in both ARQ (Protege) and RDFLib.
#   - Alarms with no conditions (## TODO placeholders) are excluded via FILTER EXISTS.
#   - STRAFTER() is NOT used: Protege runs Sesame 2.7 which does not support it.
#     Full IRIs are used instead (local name visible after the # fragment).
#
# Results: one row per duplicate group, ordered by group size (largest first).
#   ?groupSize  - number of alarms in the group
#   ?alarmIDs   - full IRIs of all alarms in the group (local name after #)
#   ?alarmLabels - alarm message labels for the group

PREFIX dev:    <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#>
PREFIX common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#>
PREFIX clin:   <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#>
PREFIX inst:   <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?canonical
       (COUNT(DISTINCT ?member) AS ?groupSize)
       (GROUP_CONCAT(DISTINCT STR(?member) ; separator=" | ") AS ?alarmIDs)
       (GROUP_CONCAT(DISTINCT ?label ; separator=" | ") AS ?alarmLabels)
WHERE {
  # ----------------------------
  # Subquery: assign each alarm its canonical representative
  # (the lexicographically minimum equivalent alarm, by IRI string)
  # ----------------------------
  {
    SELECT ?member (MIN(STR(?equiv)) AS ?canonical)
    WHERE {
      ?member a dev:AlertConditionDescription .
      ?equiv  a dev:AlertConditionDescription .

      # Exclude TODO placeholders (no conditions at all)
      FILTER EXISTS { { ?member dev:requiresCondition ?x } UNION { ?member dev:impliesCondition ?x } }
      FILTER EXISTS { { ?equiv  dev:requiresCondition ?x } UNION { ?equiv  dev:impliesCondition ?x } }

      # Required conditions: member = equiv  (bidirectional subset)
      FILTER NOT EXISTS { ?member dev:requiresCondition ?rc . FILTER NOT EXISTS { ?equiv  dev:requiresCondition ?rc . } }
      FILTER NOT EXISTS { ?equiv  dev:requiresCondition ?rc . FILTER NOT EXISTS { ?member dev:requiresCondition ?rc . } }

      # Implied conditions: member = equiv  (bidirectional subset)
      FILTER NOT EXISTS { ?member dev:impliesCondition ?ic .  FILTER NOT EXISTS { ?equiv  dev:impliesCondition ?ic . } }
      FILTER NOT EXISTS { ?equiv  dev:impliesCondition ?ic .  FILTER NOT EXISTS { ?member dev:impliesCondition ?ic . } }
    }
    GROUP BY ?member
  }

  ?member dev:alarmMessageLabel ?label .
}
GROUP BY ?canonical
HAVING (COUNT(DISTINCT ?member) > 1)
ORDER BY DESC(?groupSize) ?canonical

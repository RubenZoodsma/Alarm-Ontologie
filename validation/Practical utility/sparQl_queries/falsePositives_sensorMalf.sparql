
PREFIX inst: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#>
PREFIX dev:  <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# FP-2 — Sensor-malfunction suppression
# Returns every (malfunction-trigger alarm, target alarm) pair that shares a
# SensorConnectivityCondition.  The Python rule uses these pairs to suppress
# any target alarm whose alarm_start falls within the malfunction window
# (malfunction alarm_start … alarm_eind + 30 s grace period).
# Both physiological AND technical target alarms are included.

SELECT DISTINCT ?malfLabel ?targetLabel ?sharedSensorCond
WHERE {
    # --- malfunction alarm: technical alarm that requires a SensorFaultCondition ---
    ?malfACD a dev:AlertConditionDescription ;
             dev:alarmCategory inst:technicalAlarmGroup ;
             dev:alarmMessageLabel ?malfLabel ;
             dev:requiresCondition ?sharedSensorCond ;
             dev:requiresCondition ?faultCond .

    # sharedSensorCond must be a SensorConnectivityCondition (semantic class)
    ?sharedSensorCond a ?connType .
    ?connType rdfs:subClassOf* dev:SensorConnectivityCondition .

    # faultCond must be a SensorFaultCondition (hardware fault / disconnection)
    # — excludes pure signal-quality conditions (SignalQualityCondition)
    ?faultCond a ?faultType .
    ?faultType rdfs:subClassOf* dev:SensorFaultCondition .

    # --- any alarm (physiological OR technical) sharing the same sensor-connectivity condition ---
    ?targetACD a dev:AlertConditionDescription ;
               dev:alarmMessageLabel ?targetLabel ;
               dev:requiresCondition ?sharedSensorCond .

    # do not suppress the malfunction alarm itself
    FILTER(?malfACD != ?targetACD)
}
ORDER BY ?malfLabel ?targetLabel
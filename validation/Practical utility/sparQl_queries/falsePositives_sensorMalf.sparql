
PREFIX inst: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#>
PREFIX dev:  <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#>
PREFIX common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# FP-2 — Sensor-malfunction suppression
# Returns every (malfunction-trigger alarm, target alarm) pair that refers to the
# same sensor entity.
#
# Trigger: a technical alarm that requiresCondition a SensorConnectivityCondition
#          whose dev:hasValue is common:Disconnected, identifying sensor entity ?sensorEnt.
# Target:  any other alarm that requiresCondition any condition about the same
#          ?sensorEnt — i.e. any alarm that depends on that sensor being connected.
#
# The Python rule uses these pairs to suppress target alarms whose alarm_start
# falls within the malfunction window (malfunction alarm_start … alarm_eind + 30 s).

SELECT DISTINCT ?malfLabel ?targetLabel ?sensorEnt
WHERE {
    # --- malfunction alarm: requires a Disconnected SensorConnectivityCondition ---
    ?malfACD a dev:AlertConditionDescription ;
             dev:alarmCategory inst:technicalAlarmGroup ;
             dev:alarmMessageLabel ?malfLabel ;
             dev:requiresCondition ?disconnCond .

    ?disconnCond a dev:SensorConnectivityCondition ;
                 dev:hasValue common:Disconnected ;
                 dev:aboutEntity ?sensorEnt .

    # --- target alarm: requires any condition about the same sensor entity ---
    ?targetCond dev:aboutEntity ?sensorEnt .

    ?targetACD a dev:AlertConditionDescription ;
               dev:alarmMessageLabel ?targetLabel ;
               dev:requiresCondition ?targetCond .

    # do not suppress the malfunction alarm itself
    FILTER(?malfACD != ?targetACD)
}
ORDER BY ?malfLabel ?targetLabel

######################################################################################################
# FILE: 3_organ.ttl
# DESCRIPTION:
#   Contains instances of :Organ — e.g., Lung, Heart, Kidney.
#   Each organ is part of a physiological system and may have one or more physiological processes.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/organ>
    a owl:Ontology ;
    owl:versionIRI <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/organ/v1> ;
    rdfs:label "Clinical Instances: Organs" ;
    rdfs:comment "Instance-level data for human organs in the clinical domain." .

######################################################################################################
# BLUEPRINT — ORGAN INSTANCE STRUCTURE
#
#
# Data Properties:
#   - hasSNOMEDCode (xsd:string)        e.g. "39607008"   # Lung
#   - hasFunctionalState (ObjectProperty)             e.g. "Normal"
# Object Properties:
#   - partOfSystem → PhysiologicalSystem
#       e.g. :Lung_1 clin:partOfSystem :Pulmonary_System_1
#   - hasPhysiologicalProcess → PhysiologicalProcess
#       e.g. :Lung_1 clin:hasPhysiologicalProcess :Pulmonary_Oxygenation_1
#
# Example instance:
#   :Lung_1 a clin:Organ ;
#       clin:hasSNOMEDCode "39607008" ;
#       clin:partOfSystem :Pulmonary_System_1 ;
#       clin:hasPhysiologicalProcess :Pulmonary_Oxygenation_1 .
######################################################################################################

### Organs:
# - Lung
# - Heart
# - Kidney [Not modelled here]
# - Liver [Not modelled here]
# - Brain
# - Skin

:Lungs a clin:Organ ;
    clin:hasSNOMEDCode "UNKNOWN" ;
    clin:hasFunctionalState "UNKNOWN" ;
    clin:partOfSystem :Pulmonary_System ;
    clin:hasPhysiologicalProcess :Pulmonary_Oxygenation_Process, :Pulmonary_Ventilation_Process, :Pulmonary_Perfusion_Process .

:Heart a clin:Organ ;
    clin:hasSNOMEDCode "UNKNOWN" ;
    clin:hasFunctionalState "UNKNOWN" ;
    clin:partOfSystem :Cardiovascular_System ;
    clin:hasPhysiologicalProcess :Pulmonary_Perfusion_Process, :Systemic_Perfusion_Process, :Cutaneous_Perfusion_Process .

:Skin a clin:Organ ;
    clin:hasSNOMEDCode "UNKNOWN" ;
    clin:hasFunctionalState "UNKNOWN" ;
    clin:partOfSystem :Integumentary_System ;
    clin:hasPhysiologicalProcess :Cutaneous_Perfusion_Process .
######################################################################################################
# FILE: 4_physiologicalProcess.ttl
# DESCRIPTION:
#   Contains instances of :PhysiologicalProcess — mechanisms such as gas exchange or perfusion.
#   Each process occurs in an organ and produces one or more physiological properties.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/physiologicalProcess>
    a owl:Ontology ;
    owl:versionIRI <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/physiologicalProcess/v1> ;
    rdfs:label "Clinical Instances: Physiological Processes" ;
    rdfs:comment "Instance-level data for physiological processes in the clinical domain." .

######################################################################################################
# BLUEPRINT — PHYSIOLOGICALPROCESS INSTANCE STRUCTURE
#
# Data Properties:
#   - hasState (xsd:string)             e.g. "Active"
#
# Object Properties:
#   - occursInOrgan → Organ
#       e.g. :Pulmonary_Oxygenation_1 clin:occursInOrgan :Lung_1
#   - producesProperty → PhysiologicalProperty
#       e.g. :Pulmonary_Oxygenation_1 clin:producesProperty :SaO2_Property_1
#   - dependsOnProcess → PhysiologicalProcess
#       e.g. :Oxygenation_1 clin:dependsOnProcess :Ventilation_1
#
# Example instance:
#   :Pulmonary_Oxygenation_1 a clin:PhysiologicalProcess ;
#       clin:occursInOrgan :Lung_1 ;
#       clin:producesProperty :SaO2_Property_1 ;
#       clin:hasState "Active" .
######################################################################################################

### Physiological processes:
# - Oxygenation
# - Ventilation
# - Perfusion  

:Pulmonary_Oxygenation_Process a clin:PhysiologicalProcess ;
    clin:occursInOrgan :Lung ;
    clin:producesProperty :Arterial_Oxygenation_Property ;
    clin:hasState "Unknown" .

:Pulmonary_Ventilation_Process a clin:PhysiologicalProcess ;
    clin:occursInOrgan :Lung ;
    clin:producesProperty :RR_Property ;
    clin:hasState "Unknown" .

:Pulmonary_Diffusion_Process a clin:PhysiologicalProcess ;
    clin:occursInOrgan :Lung ;
    clin:producesProperty :Alveolar_CarbonDioxide_Property, :Arterial_Oxygenation_Property ;
    clin:hasState "Unknown" .

:Cardiac_Contraction_Process a clin:PhysiologicalProcess ;
    clin:occursInOrgan :Heart ;
    clin:producesProperty :Cardiac_Contractile_Frequency_Property ;
    clin:hasState "Unknown" .

:Thermoregulation_Process a clin:PhysiologicalProcess ;
    clin:occursInOrgan :Skin ;
    clin:producesProperty :Skin_Temp_Property , :Core_Temp_Property ;
    clin:hasState "Unknown" .

:Arterial_Perfusion_Process a clin:PhysiologicalProcess ;
    clin:occursInOrgan :Heart ;
    clin:producesProperty :ABP_Systolic_Property , :ABP_Diastolic_Property, :ABP_Mean_Property ;
    clin:hasState "Unknown" .
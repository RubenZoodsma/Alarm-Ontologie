######################################################################################################
# FILE: 5_physiologicalProperty.ttl
# DESCRIPTION:
#   Contains instances of :PhysiologicalProperty — measurable biological quantities (e.g., SaO2, HR).
#   These properties link directly to device metrics for interoperability.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/physiologicalProperty>
    a owl:Ontology ;
    owl:versionIRI <https://github.com/RubenZoodsm/Alarm-Ontologie/ontology/instances/clinical/physiologicalProperty/v1> ;
    rdfs:label "Clinical Instances: Physiological Properties" ;
    rdfs:comment "Instance-level data for physiological properties (measurable characteristics) in the clinical domain." .

######################################################################################################
# BLUEPRINT — PHYSIOLOGICALPROPERTY INSTANCE STRUCTURE
#
# Data Properties:
#   - hasValue (xsd:decimal)            e.g. 94
#   - hasUnit (xsd:string)              e.g. "%"
#   - hasSNOMEDCode (xsd:string)        e.g. "103228002"   # Arterial O2 saturation
#   - hasState (xsd:string)             e.g. "Low"
#
# Object Properties:
#   - partOfProcess → PhysiologicalProcess
#       e.g. :SaO2_Property_1 clin:partOfProcess :Pulmonary_Oxygenation_1
#
# Example instance:
#   :SaO2_Property_1 a clin:PhysiologicalProperty ;
#       clin:hasValue 94 ;
#       clin:hasUnit "%" ;
#       clin:hasState "Low" ;
#       clin:partOfProcess :Pulmonary_Oxygenation_1 .
######################################################################################################

### Physiological properties:
# - Arterial Oxygen Saturation (SaO2)
# - Respiratory Rate (RR)
# - Cardiac Output (CO)
# - Cardiac electric activity (ECG)
# - Arterial Blood Pressure (ABP)
# - Peripheral cardiac pulse (PPG)

:Arterial_Oxygenation_Property a clin:PhysiologicalProperty ;
    rdfs:label "Arterial Oxygenation" ;
    clin:hasUnit "%" ;
    clin:hasSNOMEDCode "103228002" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Pulmonary_Oxygenation_Process ;
    common:measuredByMetric :SpO2_Metric .

:Cardiac_Electrical_Depolarization_Property a clin:PhysiologicalProperty ;
    rdfs:label "Cardiac Electrical Depolarization" ;
    clin:hasUnit "mV" ;
    clin:hasSNOMEDCode "364075005" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Cardiac_Contraction_Process ;
    common:measuredByMetric :ST_II_Metric, :ST_V_Metric .

:Body_Temperature_Property a clin:PhysiologicalProperty ;
    rdfs:label "Body Temperature" ;
    rdfs:subClassOf clin:PhysiologicalProperty ;
    clin:hasUnit "°C" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Thermoregulation_Process ;
    common:measuredByMetric :Skin_Temp_Metric, :Core_Temp_Metric .

:Temperature_Skin_Property a clin:PhysiologicalProperty ;
    rdfs:label "Skin Temperature" ;
    rdfs:subClassOf :Body_Temperature_Property ;
    clin:hasUnit "°C" ;
    clin:hasSNOMEDCode "386725007" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Thermoregulation_Process ;
    common:measuredByMetric :Skin_Temp_Metric .

:Temperature_Core_Property a clin:PhysiologicalProperty ;
    rdfs:label "Core Temperature" ;
    rdfs:subClassOf :Body_Temperature_Property ;
    clin:hasUnit "°C" ;
    clin:hasSNOMEDCode "386724002" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Thermoregulation_Process ;
    common:measuredByMetric :Core_Temp_Metric .

:ABP_Systolic_Property a clin:PhysiologicalProperty ;
    rdfs:label "ABP Systolic" ;
    clin:hasUnit "mmHg" ;
    clin:hasSNOMEDCode "271649006" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Arterial_Perfusion_Process ;
    common:measuredByMetric :ABP_Systolic_Metric .

:ABP_Diastolic_Property a clin:PhysiologicalProperty ;
    rdfs:label "ABP Diastolic" ;
    clin:hasUnit "mmHg" ;
    clin:hasSNOMEDCode "271650006" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Arterial_Perfusion_Process ;
    common:measuredByMetric :ABP_Diastolic_Metric .

:ABP_Mean_Property a clin:PhysiologicalProperty ;
    rdfs:label "ABP Mean" ;
    clin:hasUnit "mmHg" ;
    clin:hasSNOMEDCode "271651005" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Arterial_Perfusion_Process ;
    common:measuredByMetric :ABP_Mean_Metric .

:Alveolar_CarbonDioxide_Property a clin:PhysiologicalProperty ;
    rdfs:label "Alveolar Carbon Dioxide" ;
    clin:hasUnit "mmHg" ;
    clin:hasSNOMEDCode "271650006" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Pulmonary_Diffusion_Process ;
    common:measuredByMetric :EtCO2_Metric .

:Cardiac_Contractile_Frequency_Property a clin:PhysiologicalProperty ;
    rdfs:label "Cardiac Contractile Frequency" ;
    clin:hasUnit "bpm" ;
    clin:hasSNOMEDCode "364075005" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Cardiac_Rate_Process ;        ## moved from Cardiac_Contraction_Process
    common:measuredByMetric :PulseRate_Metric ,
                            :ElectricHeartRate_Metric . ## ECG-derived heart rate (e.g. Asystolie)

:Pulmonary_Ventilation_Property a clin:PhysiologicalProperty ;
    rdfs:label "Pulmonary Ventilation" ;
    clin:hasUnit "breaths/min" ;
    clin:hasSNOMEDCode "86290005" ;
    common:hasStateInstance common:Unknown ;
    common:measuredByMetric :RespiratoryRate_Metric .

:Transcutaneous_CO2_Property a clin:PhysiologicalProperty ;
    rdfs:label "Transcutaneous CO2" ;
    clin:hasUnit "mmHg" ;
    clin:hasSNOMEDCode "250750003" ;
    rdfs:comment "Partial pressure of CO2 measured transcutaneously through the skin. Reflects arterial/tissue pCO2 and is used as a non-invasive proxy for arterial CO2. Distinct from alveolar EtCO2; both reflect pulmonary CO2 elimination." ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Pulmonary_Diffusion_Process ;
    common:measuredByMetric :tcpCO2_Metric .

:CO2_Property a clin:PhysiologicalProperty ;
    rdfs:label "CO2 Property" ;
    rdfs:comment "Generic superclass property representing any CO2 measurement (alveolar EtCO2 or transcutaneous tcpCO2). Used in conditions where the alarm applies to CO2 monitoring regardless of modality (e.g. CO2 auto nulling, CO2 adapter error alarms). Sub-types: :Alveolar_CarbonDioxide_Property, :Transcutaneous_CO2_Property." ;
    clin:hasUnit "mmHg" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Pulmonary_Diffusion_Process .

:ElectricHeartRate_Property a clin:PhysiologicalProperty ;
    rdfs:label "Electric Heart Rate" ;
    rdfs:comment "ECG-derived cardiac rate: the frequency of electrical depolarisation events as measured from the ECG waveform. Sub-type of :Cardiac_Contractile_Frequency_Property, specifically reflecting electrophysiological activity rather than mechanical pulse. Used for asystole detection." ;
    clin:hasUnit "bpm" ;
    clin:hasSNOMEDCode "364075005" ;
    common:hasStateInstance common:Unknown ;
    clin:partOfProcess :Cardiac_Rate_Process ;
    common:measuredByMetric :ElectricHeartRate_Metric .

######################################################################################################
# FILE: 1_patient.ttl
# DESCRIPTION:
#   Contains instances of the class :Patient within the AlarmOnto Clinical Ontology.
#   Each individual represents a patient under monitoring, with demographic and 
#   physiological context references (e.g., links to physiological systems).
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/patient>
    a owl:Ontology ;
    owl:versionIRI <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/patient/v1> ;
    rdfs:label "Clinical Instances: Patient" ;
    rdfs:comment "Instance-level data for patients in the clinical domain." .

######################################################################################################
# BLUEPRINT — PATIENT INSTANCE STRUCTURE
#
# Data Properties:
#   - hasIdentifier (xsd:string) e.g. "12345"
#   - hasAge (xsd:integer) e.g. 63
#   - hasSex (xsd:string) e.g. "Female"
#   - hasState (xsd:string) e.g. "Under monitoring"
#
# Object Properties:
#   - hasPhysiologicalSystem → PhysiologicalSystem
#       e.g. :Patient_001 hasPhysiologicalSystem :Pulmonary_System_1
#
# Example instance:
#   :Patient_001 a clin:Patient ;
#       clin:hasIdentifier "12345" ;
#       clin:hasAge 63 ;
#       clin:hasSex "Female" ;
#       clin:hasState "Under monitoring" ;
#       clin:hasPhysiologicalSystem :Pulmonary_System_1 .
######################################################################################################

:Patient a clin:Patient ;
    rdfs:label "Generic Patient" ;
    rdfs:comment "Generic patient entity for alarm condition modeling" .

:JohnDoe a clin:Patient ;
    clin:hasPhysiologicalSystem :Pulmonary_System .

######################################################################################################
# FILE: 2_physiologicalSystem.ttl
# DESCRIPTION:
#   Contains instances of :PhysiologicalSystem — such as pulmonary, cardiovascular, or nervous systems.
#   Each system can contain one or more Organs and belongs to a Patient.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/physiologicalSystem>
    a owl:Ontology ;
    owl:versionIRI <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/clinical/physiologicalSystem/v1> ;
    rdfs:label "Clinical Instances: Physiological Systems" ;
    rdfs:comment "Instance-level data for physiological systems in the clinical domain." .

######################################################################################################
# BLUEPRINT — PHYSIOLOGICALSYSTEM INSTANCE STRUCTURE
#
# Data Properties:
#   - hasSNOMEDCode (xsd:string)        e.g. "39057004"   # Pulmonary system
#   - hasFunctionalState (ObjectProperty)             e.g. "Stable"
#
# Object Properties:
#   - partOfPatient → Patient
#       e.g. :Pulmonary_System_1 clin:partOfPatient :Patient_001
#   - hasOrgan → Organ
#       e.g. :Pulmonary_System_1 clin:hasOrgan :Lung_1
#
# Example instance:
#   :Pulmonary_System_1 a clin:PhysiologicalSystem ;
#       clin:hasSNOMEDCode "39057004" ;
#       clin:hasFunctionalState "Stable" ;
#       clin:partOfPatient :Patient_001 ;
#       clin:hasOrgan :Lung_1 .
######################################################################################################

### Physiological systems:
# - Pulmonary System
# - Cardiovascular System
# - Nervous System [Not modelled here]
# - Immune System [Not modelled here]
# - Digestive System [Not modelled here]
# - Renal System [Not modelled here]
# - Musculoskeletal System [Not modelled here]
# - Endocrine System [Not modelled here]

:Pulmonary_System a clin:PhysiologicalSystem ;
    clin:hasSNOMEDCode "UNKNOWN" ;
    clin:hasFunctionalState "UNKNOWN" ;
    clin:partOfPatient :Patient ;
    clin:hasOrgan :Lung .

:Cardiovascular_System a clin:PhysiologicalSystem ;
    clin:hasSNOMEDCode "UNKNOWN" ;
    clin:hasFunctionalState "UNKNOWN" ;
    clin:partOfPatient :Patient ;
    clin:hasOrgan :Heart , :Vessels .

:Integumentary_System a clin:PhysiologicalSystem ;
    clin:hasSNOMEDCode "UNKNOWN" ;
    clin:hasFunctionalState "UNKNOWN" ;
    clin:partOfPatient :Patient ;
    clin:hasOrgan :Skin .

:Endocrine_System a clin:PhysiologicalSystem ;
    clin:hasSNOMEDCode "UNKNOWN" ;
    clin:hasFunctionalState "UNKNOWN" ;
    clin:partOfPatient :Patient .

:Nervous_System a clin:PhysiologicalSystem ;
    clin:hasSNOMEDCode "UNKNOWN" ;
    clin:hasFunctionalState "UNKNOWN" ;
    clin:partOfPatient :Patient ;
    clin:hasOrgan :Brain .
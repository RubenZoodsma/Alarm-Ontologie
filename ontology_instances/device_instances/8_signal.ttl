######################################################################################################
# FILE: 8_signal.ttl
# DESCRIPTION:
#   Instances of :Signal represent time-series data produced by sensors. 
#   Equivalent to RTMSS Real-Time Sample Arrays (RTSA).
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/signal>
    a owl:Ontology ;
    rdfs:label "Signal Instances" .

######################################################################################################
# BLUEPRINT — SIGNAL INSTANCE STRUCTURE
#
# Data Properties:
#   - hasSignalQuality (xsd:string)     e.g. "Good"
#   - hasSamplingRate (xsd:decimal)     e.g. 125
#   - hasUnit (xsd:string)              e.g. "%"
#
# Object Properties:
#   - isProducedBy → Sensor
#   - inputToProcess → MeasurementProcess
#
# Example:
#   :SpO2_Signal_1 a dev:Signal ;
#       dev:hasSignalQuality "Good" ;
#       dev:hasSamplingRate 125 ;
#       dev:isProducedBy :O2Sensor_1 ;
#       dev:inputToProcess :SpO2_Process_1 .
######################################################################################################

:PulseOximetry_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :Pulse_Oximeter_Sensor ;
    dev:inputToProcess :PulseOximetry_MeasurementProcess .

:ECG_RA_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .

:ECG_RL_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .

:ECG_LA_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .

:ECG_LL_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .    

:ECG_V1_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .

:ECG_V2_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .

:ECG_V3_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .

:ECG_V4_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .

:ECG_V5_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;
    dev:inputToProcess :ECG_MeasurementProcess .

:ECG_V6_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ECG_Electrodes_Sensor ;   
    dev:inputToProcess :ECG_MeasurementProcess .

:Temp_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :Temperature_Sensor ;
    dev:inputToProcess :Temp_MeasurementProcess .

:SkinTemp_Signal a dev:Signal, :Temp_Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :Skin_Temperature_Sensor ;
    dev:inputToProcess :SkinTemp_MeasurementProcess .

:CoreTemp_Signal a dev:Signal, :Temp_Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :Core_Temperature_Sensor ;
    dev:inputToProcess :CoreTemp_MeasurementProcess .

:ABP_Waveform_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :ABP_Transducer_Sensor ;
    dev:inputToProcess :ABP_Waveform_MeasurementProcess .

:Capno_Waveform_Signal a dev:Signal ;
    common:hasQualityIndicator "Good" ;
    common:hasStateInstance common:Transmitting ;
    dev:isProducedBy :Capnography_Sensor ;
    dev:inputToProcess :Capno_Waveform_MeasurementProcess .

:ECG_SignalGroup a dev:SignalGroup ;
    rdfs:label "ECG Signal Group" ;
    rdfs:comment "Group aggregating all individual ECG lead signals (RA, RL, LA, LL, V1–V6). Used as the collective entity for conditions that apply to the entire ECG signal ensemble rather than a single lead (e.g. noise, silencing of ECG alarms)." ;
    dev:hasComponent :ECG_RA_Signal , :ECG_RL_Signal , :ECG_LA_Signal , :ECG_LL_Signal ,
                     :ECG_V1_Signal , :ECG_V2_Signal , :ECG_V3_Signal , :ECG_V4_Signal ,
                     :ECG_V5_Signal , :ECG_V6_Signal .

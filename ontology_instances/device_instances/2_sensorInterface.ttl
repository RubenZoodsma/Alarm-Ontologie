######################################################################################################
# FILE: 2_sensorInterface.ttl
# DESCRIPTION:
#   Instances of :SensorInterface represent physical or logical ports connecting sensors to the device.
#   Corresponds to RTMSS Sensor Interface (SEN).
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/sensorInterface>
    a owl:Ontology ;
    rdfs:label "Sensor Interface Instances" .

######################################################################################################
# BLUEPRINT — SENSORINTERFACE INSTANCE STRUCTURE
#
# Data Properties:
#   - hasPortType (xsd:string)          e.g. "Analog"
#   - hasConnectorID (xsd:string)       e.g. "PortA1"
#
# Object Properties:
#   - partOfFunctionalUnit → FunctionalUnit
#       e.g. :O2Interface_1 dev:partOfFunctionalUnit :GasDeliveryUnit_1
#   - connectsSensor → Sensor
#       e.g. :O2Interface_1 dev:connectsSensor :O2Sensor_1
#
# Example:
#   :O2Interface_1 a dev:SensorInterface ;
#       dev:hasPortType "Analog" ;
#       dev:hasConnectorID "PortA1" ;
#       dev:connectsSensor :O2Sensor_1 .
######################################################################################################

:PulseOximeter_Interface a dev:SensorInterface ;
    dev:isPartOfDevice :PhilipsMonitor ;
    dev:partOfFunctionalUnit :PulseOximetry_Module ;
    dev:connectsSensor :Pulse_Oximeter_Sensor .

:ECG_Interface a dev:SensorInterface ;
    dev:isPartOfDevice :PhilipsMonitor ;
    dev:partOfFunctionalUnit :ECG_Module ;
    dev:connectsSensor :ECG_LA_Sensor, :ECG_LL_Sensor, :ECG_RA_Sensor, :ECG_RL_Sensor, :ECG_V1_Sensor, :ECG_V2_Sensor, :ECG_V3_Sensor, :ECG_V4_Sensor, :ECG_V5_Sensor, :ECG_V6_Sensor .

:SkinTemperature_Probe_Interface a dev:SensorInterface ;
    dev:isPartOfDevice :PhilipsMonitor ;
    dev:partOfFunctionalUnit :Temp_Module ;
    dev:connectsSensor :SkinTemperature_Probe_Sensor .

:CoreTemperature_Probe_Interface a dev:SensorInterface ;
    dev:isPartOfDevice :PhilipsMonitor ;
    dev:partOfFunctionalUnit :Temp_Module ;
    dev:connectsSensor :CoreTemperature_Probe_Sensor .

:IBP_Transducer_Interface a dev:SensorInterface ;
    dev:isPartOfDevice :PhilipsMonitor ;
    dev:partOfFunctionalUnit :IBP_Module ;
    dev:connectsSensor :ABP_Transducer_Sensor .

:CO2_Sensor_Interface a dev:SensorInterface ;
    dev:isPartOfDevice :PhilipsMonitor ;
    dev:partOfFunctionalUnit :Capnography_Module ;
    dev:connectsSensor :Capnography_Sensor .
######################################################################################################
# FILE: 2_sensorInterface.ttl
# DESCRIPTION:
#   Instances of :SensorInterface represent physical or logical ports connecting sensors to the device.
#   Corresponds to RTMSS Sensor Interface (SEN).
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/sensorInterface>
    a owl:Ontology ;
    rdfs:label "Sensor Interface Instances" ;

######################################################################################################
# BLUEPRINT — SENSORINTERFACE INSTANCE STRUCTURE
#
# Data Properties:
#   - hasPortType (xsd:string)          e.g. "Analog"
#   - hasConnectorID (xsd:string)       e.g. "PortA1"
#
# Object Properties:
#   - partOfFunctionalUnit → FunctionalUnit
#       e.g. :O2Interface_1 dev:partOfFunctionalUnit :GasDeliveryUnit_1
#   - connectsSensor → Sensor
#       e.g. :O2Interface_1 dev:connectsSensor :O2Sensor_1
#
# Example:
#   :O2Interface_1 a dev:SensorInterface ;
#       dev:hasPortType "Analog" ;
#       dev:hasConnectorID "PortA1" ;
#       dev:connectsSensor :O2Sensor_1 .
######################################################################################################

:SpO2_SensorInterface a dev:SensorInterface ;
    dev:hasPortType "Digital" ;
    dev:hasConnectorID "SpO2_Port" ;
    dev:partOfFunctionalUnit :SpO2_Module ;
    dev:connectsSensor :Pulse_Oximeter_Sensor .

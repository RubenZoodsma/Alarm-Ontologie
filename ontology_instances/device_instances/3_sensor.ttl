######################################################################################################
# FILE: 3_sensor.ttl
# DESCRIPTION:
#   Instances of :Sensor represent individual sensors within functional units
#   (e.g., pulse oximeter sensor, ECG electrodes). Equivalent to IEEE 11073 VMD.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/sensor>
    a owl:Ontology ;
    rdfs:label "Sensor Instances" .

######################################################################################################
# BLUEPRINT — SENSOR INSTANCE STRUCTURE
#
# Data Properties:
#   - hasAccuracy (xsd:decimal)         e.g. 0.95
#   - hasResolution (xsd:decimal)       e.g. 0.1
#   - hasState (xsd:string)             e.g. "Connected"
#
# Object Properties:
#   - hasDeviceChannel → DeviceChannel
#       e.g. :Pulse_Oximeter_Sensor dev:hasDeviceChannel :SpO2_Channel
#
# Note: Sensors are the measurement components within functional units
##########################################

:Pulse_Oximeter_Sensor a dev:Sensor ;
    dev:hasAccuracy 0.95 ;
    common:hasStateInstance common:Connected ;
    dev:hasDeviceChannel :SpO2_Channel .

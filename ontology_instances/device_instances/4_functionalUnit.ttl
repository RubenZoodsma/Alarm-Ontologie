######################################################################################################
# FILE: 4_functionalUnit.ttl
# DESCRIPTION:
#   Instances of :FunctionalUnit represent logical subsystems in a device 
#   (e.g. Gas Delivery Unit, ECG Module). Equivalent to RTMSS VMD.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/functionalUnit>
    a owl:Ontology ;
    rdfs:label "Functional Unit Instances" .

######################################################################################################
# BLUEPRINT — FUNCTIONALUNIT INSTANCE STRUCTURE
#
# Data Properties:
#   - hasDescription (xsd:string)       e.g. "Gas Delivery Unit"
#   - hasOperationalState (ObjectProperty)             e.g. "Active"
#
# Object Properties:
#   - partOfDevice → PhysicalDevice
#   - hasDeviceChannel → DeviceChannel
#
# Example:
#   :GasDeliveryUnit_1 a dev:FunctionalUnit ;
#       dev:hasDescription "Gas Delivery Unit" ;
#       dev:hasState "Active" ;
#       dev:partOfDevice :Ventilator_1 ;
#       dev:hasDeviceChannel :FlowChannel_1 .
######################################################################################################

:PulseOximetry_Module a dev:FunctionalUnit ;
    dev:hasDescription "Pulse Oximetry Module" ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor ;
    dev:hasDeviceChannel :SpO2_Channel .

:ECG_Module a dev:FunctionalUnit ;
    dev:hasDescription "ECG Module" ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor ;
    dev:hasDeviceChannel :ECG_Channel .

:Temp_Module a dev:FunctionalUnit ;
    dev:hasDescription "Temperature Module" ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor ;
    dev:hasDeviceChannel :Temp_Channel .

:IBP_Module a dev:FunctionalUnit ;
    dev:hasDescription "Invasive Blood Pressure Module" ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor ;
    dev:hasDeviceChannel :ABP_Channel .

:Battery_Module a dev:FunctionalUnit ;
    dev:hasDescription "Battery Module" ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor .

:Capnography_Module a dev:FunctionalUnit ;
    dev:hasDescription "Capnography Module" ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor ;
    dev:hasDeviceChannel :Capno_Channel .

:SpeedpointFU a dev:FunctionalUnit ;
    dev:hasDescription "SpeedPoint Data Transfer Module" ;
    rdfs:comment "Functional unit responsible for electronic patient data transfer (SpeedPoint interface) on the Philips Monitor. Handles patient-ID synchronisation and configuration verification between the monitor and the hospital information system." ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor .

:EC10Module a dev:FunctionalUnit ;
    dev:hasDescription "EC10 ECG Cable/Measurement Module" ;
    rdfs:comment "The EC10 is the ECG measurement cable and acquisition module on the Philips IntelliVue monitor. It connects ECG electrodes to the monitor and performs lead-level signal acquisition. Alarm fires when this module is physically disconnected." ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor .

:SettingsModule a dev:FunctionalUnit ;
    dev:hasDescription "Monitor Settings/Configuration Module" ;
    rdfs:comment "Functional unit representing the settings and configuration management subsystem of the Philips Monitor. Tracks whether the current configuration has been verified by the clinician after a change." ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor .

:PatientIdentityRecord a dev:FunctionalUnit ;
    dev:hasDescription "Patient Identity Record" ;
    rdfs:comment "Software component on the Philips Monitor that stores and manages the patient identity (patient ID, admission data). Requires explicit confirmation after a patient transfer or manual ID entry — the alarm fires until the clinician confirms the identity matches the admitted patient." ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor .

:ExternalControllerModule a dev:FunctionalUnit ;
    dev:hasDescription "External Controller Interface Module" ;
    rdfs:comment "Functional unit on the Philips Monitor managing the external controller (Ext CNTR) interface — handles communication and configuration between the monitor and an external control device or central station. Alarm fires when a configuration error is detected on this interface." ;
    common:hasStateInstance common:Active ;
    dev:partOfDevice :PhilipsMonitor .

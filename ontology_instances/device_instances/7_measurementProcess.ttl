######################################################################################################
# FILE: 7_measurementProcess.ttl
# DESCRIPTION:
#   Instances of :MeasurementProcess represent algorithmic transformations 
#   converting signals to metrics.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/measurementProcess>
    a owl:Ontology ;
    rdfs:label "Measurement Process Instances" .

######################################################################################################
# BLUEPRINT — MEASUREMENTPROCESS INSTANCE STRUCTURE
#
# Data Properties:
#   - hasAlgorithm (xsd:string) e.g. "Fourier transform + calibration"
#   - hasLatency (xsd:decimal) e.g. 0.2
#   - hasState (xsd:string) e.g. "Enabled"
#
# Object Properties:
#   - takesSignal → Signal
#   - producesMetric → Metric
#
# Example:
#   :SpO2_Process_1 a dev:MeasurementProcess ;
#       dev:hasAlgorithm "Fourier + calibration" ;
#       dev:hasLatency 0.2 ;
#       dev:takesSignal :SpO2_Signal_1 ;
#       dev:producesMetric :SpO2_Metric_1 .
######################################################################################################

:PulseOximetry_MeasurementProcess a dev:MeasurementProcess ;
    dev:takesSignal :SpO2_Signal ;
    dev:producesMetric :SpO2_Metric , :PulseRate_Metric .

:ECG_Waveform_MeasurementProcess a dev:MeasurementProcess ;
    dev:takesSignal :ECG_Signal ;
    dev:producesMetric :ST_II_Metric, :ST_V_Metric .

:SkinTemp_MeasurementProcess a dev:MeasurementProcess ;
    dev:takesSignal :SkinTemp_Signal ;
    dev:producesMetric :Skin_Temp_Metric .

:CoreTemp_MeasurementProcess a dev:MeasurementProcess ;
    dev:takesSignal :CoreTemp_Signal ;
    dev:producesMetric :Core_Temp_Metric .

:ABP_Waveform_MeasurementProcess a dev:MeasurementProcess ;
    dev:takesSignal :ABP_Waveform_Signal ;
    dev:producesMetric :ABP_Diastolic_Metric, :ABP_Systolic_Metric, :ABP_Mean_Metric .

:Capno_Waveform_MeasurementProcess a dev:MeasurementProcess ;
    dev:takesSignal :Capno_Waveform_Signal ;
    dev:producesMetric :EtCO2_Metric .

######################################################################################################
# FILE: 6_Metric.ttl
# DESCRIPTION:
#   Instances of :Metric represent specific measurements or parameters
#   (e.g., SpO2 value, heart rate). Equivalent to IEEE 11073 metric objects.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/metric>
    a owl:Ontology ;
    rdfs:label "Metric Instances" .

######################################################################################################
# BLUEPRINT — METRIC INSTANCE STRUCTURE
#
# Data Properties:
#   - hasMDCCode (xsd:string)          e.g. "MDC_PULS_OXIM_SAT_O2"
#   - hasUnit (xsd:string)             e.g. "%"
#   - hasLabel (xsd:string)            e.g. "SpO2"
#   - hasOperationalState (ObjectProperty)            e.g. "Transmitting"
#
# Object Properties:
#   - generatedByProcess → MeasurementProcess
#       e.g. :SpO2_Metric dev:generatedByProcess :SpO2_MeasurementProcess
#
# Note: Metrics represent the actual measured values and their metadata
####################################################

:SpO2_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_PULS_OXIM_SAT_O2" ;
    common:hasUnit "%" ;
    dev:hasLabel "SpO2" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :PulseOximetry_MeasurementProcess .

:ST_II_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_ECG_LEAD_II_ST_SEGMENT" ;
    common:hasUnit "mV" ;
    dev:hasLabel "ST II" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :ECG_Waveform_MeasurementProcess .

:ST_V_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_ECG_LEAD_V_ST_SEGMENT" ;
    common:hasUnit "mV" ;
    dev:hasLabel "ST V" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :ECG_Waveform_MeasurementProcess .

:Temp_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_TEMP" ;
    common:hasUnit "°C" ;
    dev:hasLabel "Body Temperature" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :Temp_MeasurementProcess .

:Skin_Temp_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_TEMP_SKIN" ;
    common:hasUnit "°C" ;
    dev:hasLabel "Skin Temperature" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :SkinTemp_MeasurementProcess .

:Core_Temp_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_TEMP_CORE" ;
    common:hasUnit "°C" ;
    dev:hasLabel "Core Temperature" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :CoreTemp_MeasurementProcess .

:PulsatileHeartRate_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_PULS_OXIM_PULS_RATE" ;
    common:hasUnit "bpm" ;
    dev:hasLabel "Pulsatile Heart Rate" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :PulseOximetry_MeasurementProcess .

:ElectricHeartRate_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_ECG_HEART_RATE" ;
    common:hasUnit "bpm" ;
    dev:hasLabel "Electric Heart Rate" ;
    rdfs:comment "ECG-derived heart rate metric. Computed from the RR interval of the ECG waveform. Used for asystole detection (absent electrical activity) as distinct from pulse-oximetry-derived pulse rate." ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :ECG_Waveform_MeasurementProcess .

:ABP_Systolic_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_PRESS_BLD_ART_ABP_SYSTOLIC" ;
    common:hasUnit "mmHg" ;
    dev:hasLabel "ABP Systolic" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :ABP_Waveform_MeasurementProcess .

:ABP_Mean_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_PRESS_BLD_ART_ABP_MEAN" ;
    common:hasUnit "mmHg" ;
    dev:hasLabel "ABP Mean" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :ABP_Waveform_MeasurementProcess .

:ABP_Diastolic_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_PRESS_BLD_ART_ABP_DIASTOLIC" ;
    common:hasUnit "mmHg" ;
    dev:hasLabel "ABP Diastolic" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :ABP_Waveform_MeasurementProcess .

:EtCO2_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_CAPN_ET_CO2" ;
    common:hasUnit "mmHg" ;
    dev:hasLabel "EtCO2" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :Capno_Waveform_MeasurementProcess .  

:RespiratoryRate_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_RESP_RATE" ;
    common:hasUnit "breaths/min" ;
    dev:hasLabel "Respiratory Rate" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :ECG_Waveform_MeasurementProcess .


## Groupings of metrices for organizational purposes.

:ABP_MetricGroup a dev:MetricGroup ;
    dev:hasLabel "ABP Metric Group" ;
    dev:hasComponent :ABP_Systolic_Metric , :ABP_Mean_Metric , :ABP_Diastolic_Metric .

:tcpCO2_Metric a dev:Metric ;
    dev:hasMDCCode "MDC_PRESS_AWAY_CO2_EXP" ;
    common:hasUnit "mmHg" ;
    dev:hasLabel "Transcutaneous CO2" ;
    common:hasStateInstance common:Transmitting ;
    dev:generatedByProcess :tcpCO2_MeasurementProcess .

:CO2_MetricGroup a dev:MetricGroup ;
    dev:hasLabel "CO2 Metric Group" ;
    rdfs:comment "Group encompassing all CO2-related metrics (EtCO2 and tcpCO2). Allows conditions and alarms to reference CO2 monitoring in general without specifying the measurement modality." ;
    dev:hasComponent :EtCO2_Metric , :tcpCO2_Metric .


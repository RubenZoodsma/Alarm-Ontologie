######################################################################################################
# FILE: 9_measurementSite.ttl
# DESCRIPTION:
#   Instances of :MeasurementSite represent specific anatomical or physical placement locations
#   for sensors and monitoring devices.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/measurementSite>
    a owl:Ontology ;
    rdfs:label "Measurement Site Instances" .

######################################################################################################
# BLUEPRINT — MEASUREMENTSITE INSTANCE STRUCTURE
#
# Data Properties:
#   - hasDescription (xsd:string)       e.g. "Left hand placement"
#   - hasSNOMEDCode (xsd:string)        e.g. "368208006"  # Left hand
#
# Object Properties:
#   - (typically used as object in hasPhysicalLocation relationships)
#
# Example:
#   :LeftHand a dev:PhysicalLocation ;
#       dev:hasDescription "Left hand placement for pulse oximetry" ;
#       common:hasSNOMEDCode "368208006" .
######################################################################################################

### Hand Locations
:LeftHand a :LeftSided , dev:MeasurementSite ;
    dev:hasDescription "Left hand placement for pulse oximetry" ;
    common:hasSNOMEDCode "368208006" ;
    rdfs:label "Left Hand" .

:RightHand a :RightSided , dev:MeasurementSite ;
    dev:hasDescription "Right hand placement for pulse oximetry" ;
    common:hasSNOMEDCode "368209003" ;
    rdfs:label "Right Hand" .

### Foot Locations  
:LeftFoot a :LeftSided , dev:MeasurementSite ;
    dev:hasDescription "Left foot placement for pulse oximetry" ;
    common:hasSNOMEDCode "22335008" ;
    rdfs:label "Left Foot" .

:RightFoot a :RightSided , dev:MeasurementSite ;
    dev:hasDescription "Right foot placement for pulse oximetry" ;
    common:hasSNOMEDCode "22335008" ;
    rdfs:label "Right Foot" .

### Pre/Post Ductal Locations
:PreDuctal a dev:MeasurementSite ;
    dev:hasDescription "Pre-ductal placement (typically right hand for neonates)" ;
    common:hasSNOMEDCode "368209003" ;
    rdfs:label "Pre-ductal Location" .

:PostDuctal a dev:MeasurementSite ;
    dev:hasDescription "Post-ductal placement (typically feet for neonates)" ;
    common:hasSNOMEDCode "22335008" ;
    rdfs:label "Post-ductal Location" .

### Other Body Locations
:Earlobe a dev:MeasurementSite ;
    dev:hasDescription "Earlobe placement for pulse oximetry" ;
    common:hasSNOMEDCode "42859004" ;
    rdfs:label "Earlobe" .

:Forehead a dev:MeasurementSite ;
    dev:hasDescription "Forehead placement for pulse oximetry" ;
    common:hasSNOMEDCode "52795006" ;
    rdfs:label "Forehead" .

:LeftSided a dev:MeasurementSite ;
    dev:hasDescription "General left-sided placement (e.g. left hand, left foot)" ;
    rdfs:label "Left-sided Location" .

:RightSided a dev:MeasurementSite ;
    dev:hasDescription "General right-sided placement (e.g. right hand, right foot)" ;
    rdfs:label "Right-sided Location" .

:TerminalAirway a dev:MeasurementSite ;
    dev:hasDescription "Terminal airway placement, commonly used for mechanical ventilation and capnography" ;
    common:hasSNOMEDCode "86184006" ;
    rdfs:label "Terminal Airway" .

:Cutaneous a dev:MeasurementSite ;
    dev:hasDescription "Cutaneous (skin-surface) placement for transcutaneous monitoring (e.g. transcutaneous pCO2 sensor)" ;
    common:hasSNOMEDCode "119325001" ;
    rdfs:label "Cutaneous" .
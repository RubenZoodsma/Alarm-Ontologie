######################################################################################################
# FILE: 1_physicalDevice.ttl
# DESCRIPTION:
#   Instances of :PhysicalDevice represent physical medical devices 
#   (e.g., monitors, ventilators). Equivalent to IEEE 11073 MDS.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/physicalDevice>
    a owl:Ontology ;
    rdfs:label "Physical Device Instances" .

######################################################################################################
# BLUEPRINT — PHYSICALDEVICE INSTANCE STRUCTURE
#
# Data Properties:
#   - hasManufacturer (xsd:string)      e.g. "Philips"
#   - hasModelName (xsd:string)         e.g. "IntelliVue MP70"
#   - hasSerialNumber (xsd:string)      e.g. "SN-112358"
#   - hasUDI (xsd:string)               e.g. "(01)00884838010004"
#   - hasState (xsd:string)             e.g. "Enabled"
#
# Object Properties:
#   - hasFunctionalUnit → FunctionalUnit
#       e.g. :PhilipsMonitor_1 dev:hasFunctionalUnit :SpO2_Module_1
#
# Note: PhysicalDevice is the top-level container for all device components
######################################################################################################

# Physical device names:
# - Monitor (Philips)
# - Ventilator (Draeger, Hulbus, Datexahmedacom)
# - Thermoregulator (Medibus)

:PhilipsMonitor a dev:PhysicalDevice, dev:MonitoringDevice ;
    dev:hasManufacturer "Philips" ;
    dev:hasModelName "Unknown Model" ;
    dev:hasFunctionalUnit :SpO2_Module, :ECG_Module, :NIBP_Module, :Temp_Module, :IBP_Module, :VascPress_Module .

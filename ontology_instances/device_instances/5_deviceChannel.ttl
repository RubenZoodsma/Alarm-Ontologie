######################################################################################################
# FILE: 5_deviceChannel.ttl
# DESCRIPTION:
#   Instances of :DeviceChannel represent logical groupings of related metrics.
#   Equivalent to RTMSS Channel entities.
######################################################################################################

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/device/deviceChannel>
    a owl:Ontology ;
    rdfs:label "Device Channel Instances" ;

######################################################################################################
# BLUEPRINT — DEVICECHANNEL INSTANCE STRUCTURE
#
# Data Properties:
#   - hasLabel (xsd:string)             e.g. "Flow Measurements"
#   - hasState (xsd:string)             e.g. "Enabled"
#
# Object Properties:
#   - partOfFunctionalUnit → FunctionalUnit
#   - hasMetric → Metric
#
# Example:
#   :FlowChannel_1 a dev:DeviceChannel ;
#       dev:hasLabel "Flow Measurements" ;
#       dev:hasState "Enabled" ;
#       dev:hasMetric :FlowRateMetric_1 .
######################################################################################################

:SpO2_Channel a dev:DeviceChannel ;
    dev:hasLabel "SpO2 Measurements" ;
    common:hasStateInstance common:Enabled ;
    dev:partOfFunctionalUnit :SpO2_Module ;
    dev:hasMetric :SpO2_Metric ;
    dev:hasThresholdInterpretation common:High .

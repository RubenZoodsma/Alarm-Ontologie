@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#######################################################################
# Ontology header
#######################################################################

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/alarms>
    a owl:Ontology ;
    rdfs:label "Alarm Condition Instances (Entity-State Definition)" ;
    rdfs:comment "Defines alarm instances based on entity:state requirements for activation" ;
    owl:imports <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/alarm-specifications> .

#######################################################################
# Test Alarm: PHILIPSMONITOR - SpO2 Left High
# Using composite properties instead of separate requirement instances
#######################################################################

:LowSpO2_Def
    a dev:AlarmDefinition ;
    rdfs:label "Low SpO2 – semantic definition" ;
    rdfs:comment "Explicit documentation of the latent conditions carried by the Low SpO2 alarm." ;
    dev:requiresSpec
        :Spec_MonitorEnabled ,
        :Spec_SensorConnected ,
        :Spec_SpO2Low .

:LowSpO2Alarm
    a dev:AlarmCondition ;
    rdfs:label "PHILIPSMONITOR - SpO2 Low" ;
    rdfs:comment "Alarm triggered when monitor enabled AND sensor connected AND SpO2 interpreted as Low." ;

    # Link to the human-friendly, explicit definition
    dev:hasDefinition :LowSpO2_Def ;

    # Reasoning definition (kept for inference/classification)
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            dev:AlarmSituation

            # [A=PhilipsMonitor, B=hasStateInstance, C=Enabled]
            [ a owl:Restriction ; owl:onProperty dev:hasCondition ; owl:someValuesFrom
                [ a owl:Class ; owl:intersectionOf (
                    dev:Condition
                    [ a owl:Restriction ; owl:onProperty dev:aboutEntity ; owl:hasValue :PhilipsMonitor ]
                    [ a owl:Restriction ; owl:onProperty dev:onAttribute ; owl:hasValue common:hasStateInstance ]
                    [ a owl:Restriction ; owl:onProperty dev:hasValue ; owl:hasValue :Enabled ]
                )]
            ]

            # [A=Pulse_Oximeter_Sensor, B=hasStateInstance, C=Connected]
            [ a owl:Restriction ; owl:onProperty dev:hasCondition ; owl:someValuesFrom
                [ a owl:Class ; owl:intersectionOf (
                    dev:Condition
                    [ a owl:Restriction ; owl:onProperty dev:aboutEntity ; owl:hasValue :Pulse_Oximeter_Sensor ]
                    [ a owl:Restriction ; owl:onProperty dev:onAttribute ; owl:hasValue common:hasStateInstance ]
                    [ a owl:Restriction ; owl:onProperty dev:hasValue ; owl:hasValue :Connected ]
                )]
            ]

            # [A=SpO2_Metric, B=hasAlarmInterpretation, C=Low]
            [ a owl:Restriction ; owl:onProperty dev:hasCondition ; owl:someValuesFrom
                [ a owl:Class ; owl:intersectionOf (
                    dev:Condition
                    [ a owl:Restriction ; owl:onProperty dev:aboutEntity ; owl:hasValue :SpO2_Metric ]
                    [ a owl:Restriction ; owl:onProperty dev:onAttribute ; owl:hasValue dev:hasAlarmInterpretation ]
                    [ a owl:Restriction ; owl:onProperty dev:hasValue ; owl:hasValue :Low ]
                )]
            ]
        )
    ] .
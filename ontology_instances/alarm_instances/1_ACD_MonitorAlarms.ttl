    dev:originatesFromPhysicalEntity :PhilipsMonitor ;

    dev:requiresCondition ## Asserted knowledge - explicitly/unambiguously stated as needed for the AlertConditionState to trigger
        :Cond_PhilipsMonitor_OperationalState_Enabled ,             ## philipsMonitor is enabled
        :Cond_PulseOximetrySensor_OperationalState_Enabled ,      ## pulseOximeterSensor is connected
        :Cond_SpO2Metric_OperationalState_Enabled ,               ## SpO2 metric is being measured
        :Cond_PulseOximetrySensor_MeasurementLocation_postDuctal ,   ## pulseOximeterSensor hasMeasurementLocation = postDuctal
        ## epistemic representation
        :Cond_SpO2Metric_MagnitudeState_High                        ## SpO2_metric hasMagnitudeState = High (elevated value)  
        ;

    dev:impliesCondition ## Inferred knowledge - logically follows from asserted conditions and network reasoning.
        :Cond_Patient_HasConnectedDevice_PhilipsMonitor ,
        :Cond_Patient_HasConnectedSensor_PulseOximetry ,
        :Cond_SaO2Property_ObservationState_Monitored ,
        ## ontological interpretation of the epistemic representation
        :Cond_SaO2Property_MagnitudeState_High ,                    ## SaO2Property hasMagnitudeState = High (elevated value)
        :Cond_PulmonaryOxygenation_FunctionalState_Hyper            ## Pulmonary oxygenation process is in a hyperfunctional state 
        ## organ- and organsystem level inferrals through inheritance / reasoning
        .

:ACD_Alarm_3 ## PHILIPSMONITOR - ?? ST-II laag
    a dev:AlertConditionDescription ;
    rdfs:label "AlertConditionDescription: Semantic definition of PHILIPSMONITOR - ?? ST-II laag" ;
    rdfs:comment "Explicit documentation of the latent conditions carried by 'PHILIPSMONITOR - ?? ST-II laag'." ;

    dev:hasAlertConditionState :ACS_Alarm_3 ;
    dev:emittedPriorityLevel :mediumPriority ;
    dev:alarmMessageLabel "PHILIPSMONITOR - ?? ST-II laag" ;
    dev:alarmCategory :physiologicalAlarmGroup ;
    dev:originatesFromPhysicalEntity :PhilipsMonitor ;

    dev:requiresCondition ## Asserted knowledge - explicitly/unambiguously stated as needed for the AlertConditionState to trigger
        :Cond_PhilipsMonitor_OperationalState_Enabled ,              ## philipsMonitor is enabled
        :Cond_ECGSensorGroup_OperationalState_Enabled ,       ## ECG sensor group is connected
        :Cond_STII_Metric_OperationalState_Enabled ,             ## ST-II metric is being measured/calculated
         ## epistemic representation
        :Cond_STII_Metric_MagnitudeState_low                        ## ST-II_metric hasMagnitudeState = Low (deviant value)  
        ;

    dev:impliesCondition ## Inferred knowledge - logically follows from asserted conditions and network reasoning.
        :Cond_Patient_HasConnectedDevice_PhilipsMonitor ,
        :Cond_Patient_HasConnectedSensor_ECGSensor ,
        # ontological interpretation of the epistemic representation
        ## PM: Check later - singular ST-segment deviations are not clinically interpretable in a uniform manner.
        :Cond_CardiacDepolarizationProperty_ObservationState_Monitored , ## CardiacDepolarizationProperty is being monitored (e.g. via ST-segment analysis)
        :Cond_CardiacDepolarizationProperty_MagnitudeState_low                     ## CardiacDepolarizationProperty hasMagnitudeState = Low (deviant value)
        ## Influence of alarm 'ST-II' on process-level (cardiac contraction / depolarization) not made explicit. Interpretation of the alarm solely dependend on a single lead is not clinically feasible.
        .


@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#######################################################################
# Ontology header
#######################################################################

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/alarm-condition-descriptions>
    a owl:Ontology ;
    rdfs:label "Alarm Condition Descriptions (ACD)" ;
    rdfs:comment "Defines AlertConditionDescription instances with explicit semantic requirements for alarm activation" .

#######################################################################
# Alarm 1  | PHILIPSMONITOR - ?? SpO2l hoog	
#######################################################################

:ACD_Alarm_1 ## PHILIPSMONITOR - ?? SpO2l hoog
    a dev:AlertConditionDescription ;
    rdfs:label "AlertConditionDescription: Semantic definition of PHILIPSMONITOR - ?? SpO2l hoog" ;
    rdfs:comment "Explicit documentation of the latent conditions carried by 'PHILIPSMONITOR - ?? SpO2l hoog'." ;

    dev:hasAlertConditionState :ACS_Alarm_1 ;
    dev:emittedPriorityLevel :mediumPriority ;
    dev:alarmMessageLabel "PHILIPSMONITOR - ?? SpO2l hoog" ;
    dev:alarmCategory :physiologicalAlarmGroup ;
    dev:originatesFromPhysicalEntity :PhilipsMonitor ;

    dev:requiresCondition ## Asserted knowledge - explicitly/unambiguously stated as needed for the AlertConditionState to trigger
        :Cond_PhilipsMonitor_OperationalState_Enabled ,             ## philipsMonitor is enabled
        :Cond_PulseOximetrySensor_OperationalState_Enabled ,      ## pulseOximeterSensor is connected
        :Cond_SpO2Metric_OperationalState_Enabled ,               ## SpO2 metric is being measured
        :Cond_PulseOximetrySensor_MeasurementLocation_LeftSide ,    ## pulseOximeterSensor hasMeasurementLocation = Left
        ## epistemic representation
        :Cond_SpO2Metric_MagnitudeState_High                        ## SpO2_metric hasMagnitudeState = High (elevated value)  
        ;

    dev:impliesCondition ## Inferred knowledge - logically follows from asserted conditions and network reasoning.
        :Cond_Patient_HasConnectedDevice_PhilipsMonitor ,
        :Cond_Patient_HasConnectedSensor_PulseOximetry ,
        :Cond_SaO2Property_ObservationState_Monitored ,
        ## ontological interpretation of the epistemic representation
        :Cond_SaO2Property_MagnitudeState_High ,                    ## SaO2Property hasMagnitudeState = High (elevated value)
        :Cond_PulmonaryOxygenation_FunctionalState_Hyper            ## Pulmonary oxygenation process is in a hyperfunctional state 
        ## organ- and organsystem level inferrals through inheritance / reasoning
        .

:ACD_Alarm_2 ## PHILIPSMONITOR - ?? SpO2po hoog
    a dev:AlertConditionDescription ;
    rdfs:label "AlertConditionDescription: Semantic definition of PHILIPSMONITOR - ?? SpO2po hoog" ;

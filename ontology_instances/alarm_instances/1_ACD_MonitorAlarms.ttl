        :Cond_PhilipsMonitor_OperationalState_Enabled ,              ## philipsMonitor is enabled
        :Cond_CapnographySensor_OperationalState_Enabled ,       ## capnographySensor is connected
        :Cond_EtCO2Metric_OperationalState_Enabled ,              ## EtCO2 metric is being measured
        :Cond_CapnographySensor_MeasurementLocation_TerminalAirway ,

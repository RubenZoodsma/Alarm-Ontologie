        :Cond_EtCO2Metric_MagnitudeState_low                        ## EtCO2_metric hasMagnitudeState = Low (deviant value)
        ;
    
    dev:impliesCondition ## Inferred knowledge - logically follows from asserted conditions and network reasoning.
        ## Clinical-related inferrals
        :Cond_Patient_HasConnectedDevice_PhilipsMonitor ,
        :Cond_Patient_HasConnectedDevice_Ventilator ,
        :Cond_Patient_HasConnectedSensor_Capnography ,
        :Cond_AlveolarCO2Property_ObservationState_Monitored ,
        :Cond_PulmonarySystem_SubjectOfTherapy_MechanicalVentilation ,
        :Cond_PulmVentilationProcess_SupportModality_ExternalInvasiveSupport ,
        ## ontological interpretation of the epistemic representation
        :Cond_AlveolarCO2Property_MagnitudeState_low ,                    ## AlveolarCO2Property hasMagnitudeState = Low (deviant value)
        :Cond_PulmonaryCO2Diffusion_FunctionalState_Hyper               ## Pulmonary CO2 diffusion process is in a hyperfunctional state - note that 'co2Diffusion' as a process is a sub-class to 'pulmonary gas exchange' and modulated by other processes (e.g. ventilation, diffusion capacity).
        .



:ACD_Alarm_8 ## PHILIPSMONITOR - ABP slecht signaal
    a dev:AlertConditionDescription ;
    rdfs:label "AlertConditionDescription: Semantic definition of PHILIPSMONITOR - ABP slecht signaal" ;
    rdfs:comment "Explicit documentation of the latent conditions carried by 'PHILIPSMONITOR - ABP slecht signaal'." ;

    dev:hasAlertConditionState :ACS_Alarm_8 ;
    dev:emittedPriorityLevel :mediumPriority ;
    dev:alarmMessageLabel "PHILIPSMONITOR - ABP slecht signaal" ;
    dev:alarmCategory :technicalAlarmGroup ;
    dev:originatesFromPhysicalEntity :PhilipsMonitor ;

    dev:requiresCondition ## Asserted knowledge - explicitly/unambiguously stated as needed for the AlertConditionState to trigger
        :Cond_PhilipsMonitor_OperationalState_Enabled ,                  ## philipsMonitor is enabled
        :Cond_ArterialBloodPressureSensor_OperationalState_Enabled ,   ## arterialBloodPressureSensor is connected
        :Cond_ABPMetricGroup_OperationalState_Enabled ,                ## ABP metrics are being measured -> link the group transitively to individual components (e.g. ABP mean, ABP systolic, ABP diastolic)
         ## epistemic representation
        :Cond_ABP_Signal_QualityState_Insufficient                       ## ABP metric with low signal quality
        ;

    dev:impliesCondition ## Inferred knowledge - logically follows from asserted conditions and network reasoning.       
        :Cond_Patient_HasConnectedDevice_PhilipsMonitor ,
        :Cond_Patient_HasConnectedSensor_ABPtransducer ,
        :Cond_ArterialBloodPressureProperty_ObservationState_Monitored  ## link group, not a singular metric
        .


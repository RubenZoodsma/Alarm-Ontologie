# Alarm 1  | PHILIPSMONITOR - ?? SpO2l hoog	
#######################################################################

:ACD_Alarm_1 ## PHILIPSMONITOR - ?? SpO2l hoog
    a dev:AlertConditionDescription ;
    rdfs:label "AlertConditionDescription: Semantic definition of PHILIPSMONITOR - ?? SpO2l hoog" ;
    rdfs:comment "Explicit documentation of the latent conditions carried by 'PHILIPSMONITOR - ?? SpO2l hoog'." ;

    dev:hasAlertConditionState :ACS_Alarm_1 ;
    dev:emittedPriorityLevel :mediumPriority ;
    dev:alarmMessageLabel "PHILIPSMONITOR - ?? SpO2l hoog" ;
    dev:alarmCategory :physiologicalAlarmGroup ;
    dev:originatesFromPhysicalEntity :PhilipsMonitor ;

    dev:requiresCondition ## Asserted knowledge - explicitly/unambiguously stated as needed for the AlertConditionState to trigger
        :Cond_PhilipsMonitor_FunctionalState_Enabled ,              ## philipsMonitor is enabled
        :Cond_PulseOximetrySensor_FunctionalState_Connected ,       ## pulseOximeterSensor is connected
        :Cond_SpO2Metric_OperationalState_Available ,               ## SpO2 metric is being measured
        :Cond_SpO2Metric_ValueInterpretation_HighLimitViolation ,   ## SpO2_metric hasValueInterpretation = HighLimitViolation
        :Cond_PulseOximetrySensor_MeasurementLocation_Left          ## pulseOximeterSensor hasMeasurementLocation = Left
        ;

    dev:impliesCondition ## Inferred knowledge - logically follows from asserted conditions and network reasoning.
        :Cond_Patient_HasConnectedDevice_PhilipsMonitor ,
        :Cond_Patient_HasConnectedSensor_PulseOximetry ,
        :Cond_SaO2Property_ObservationState_Monitored ,
        :Cond_PulmOxygenation_FunctionalState_hyper
        .


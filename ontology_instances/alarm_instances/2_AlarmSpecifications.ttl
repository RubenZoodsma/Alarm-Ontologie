@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#######################################################################
# Ontology header
#######################################################################

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/alarm-specifications>
    a owl:Ontology ;
    rdfs:label "Alarm Condition Specifications" ;
    rdfs:comment "Defines reusable condition specifications for alarm definitions. Each ConditionSpec represents a requirement that an entity must have a specific attribute value." .

#######################################################################
# CONDITION SPECIFICATIONS
# These define reusable conditions that can be referenced by multiple alarms
#######################################################################

:Spec_MonitorEnabled
    a dev:ConditionSpec ;
    rdfs:label "Monitor Enabled Condition" ;
    rdfs:comment "Specification requiring that the PhilipsMonitor is in the Enabled state." ;
    dev:specEntity    :PhilipsMonitor ;
    dev:specAttribute clin:hasState ;
    dev:specValue     :Enabled .

:Spec_SensorConnected
    a dev:ConditionSpec ;
    rdfs:label "Sensor Connected Condition" ;
    rdfs:comment "Specification requiring that the Pulse_Oximeter_Sensor is in the Connected state." ;
    dev:specEntity    :Pulse_Oximeter_Sensor ;
    dev:specAttribute clin:hasState ;
    dev:specValue     :Connected .

:Spec_SpO2Low
    a dev:ConditionSpec ;
    rdfs:label "SpO2 Low Condition" ;
    rdfs:comment "Specification requiring that the SpO2_Metric has a Low alarm interpretation." ;
    dev:specEntity    :SpO2_Metric ;
    dev:specAttribute dev:hasAlarmInterpretation ;
    dev:specValue     :Low .

#######################################################################
# Additional specifications can be added here for other alarm conditions
#######################################################################

# Examples for future expansion:
# :Spec_SpO2High - for high SpO2 alarms
# :Spec_HeartRateHigh - for tachycardia alarms  
# :Spec_BloodPressureLow - for hypotension alarms
# etc.
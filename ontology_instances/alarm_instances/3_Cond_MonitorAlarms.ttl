    dev:aboutEntity :ElectricHeartRate_Property ;
    dev:onAttribute clin:hasObservationState ;
    dev:hasValue common:Monitored .

:Cond_ElectricHeartRateProperty_RateState_absent
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;

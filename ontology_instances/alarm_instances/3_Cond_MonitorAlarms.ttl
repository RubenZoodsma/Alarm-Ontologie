# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_RespRateMetric_RateState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: RespiratoryRate_Metric hasRateState Low" ;
    rdfs:comment "The respiratory rate metric value is low — the device-level impedance-derived respiratory rate is below the lower alarm threshold (bradypnea). Epistemic (device-level) counterpart to the clinical Cond_RespiratoryRateProperty_RateState_low." ;
    dev:aboutEntity :RespiratoryRate_Metric ;
    dev:onAttribute common:hasRateState ;
    dev:hasValue common:Low .

# ── IMPLIED CONDITIONS ───────────────────────────────────────────────

:Cond_RespiratoryRateProperty_RateState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Pulmonary_Ventilation_Property hasRateState Low" ;
    rdfs:comment "The pulmonary ventilation (respiratory rate) physiological property is low — the respiratory rate is below threshold (bradypnea). Ontological translation of the device metric to the clinical property :Pulmonary_Ventilation_Property." ;
    dev:aboutEntity :Pulmonary_Ventilation_Property ;
    dev:onAttribute common:hasRateState ;
    dev:hasValue common:Low .

:Cond_PulmonaryVentilationProcess_FunctionalState_Hypo
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Pulmonary_Ventilation_Process hasFunctionalState Hypo" ;
    rdfs:comment "The pulmonary ventilation process is hypofunctional — the respiratory rate is below threshold, indicating insufficient ventilatory effort (bradypnea). Inferred from low respiratory rate." ;
    dev:aboutEntity :Pulmonary_Ventilation_Process ;
    dev:onAttribute clin:hasFunctionalState ;
    dev:hasValue common:Hypo .


#######################################################################
# ALARM 56 | PHILIPSMONITOR - Lage hartfreq.  (low heart rate / bradycardia)
# (PhilipsMonitor/Patient/ECGSensor/ElectricHeartRateMetric conditions shared with above)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_ElectricHeartRateMetric_RateState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: ElectricHeartRate_Metric hasRateState Low" ;
    rdfs:comment "The electric heart rate metric value is low — the device-level ECG-derived heart rate is below the lower alarm threshold (bradycardia). Epistemic (device-level) counterpart to the clinical Cond_ElectricHeartRateProperty_RateState_low." ;
    dev:aboutEntity :ElectricHeartRate_Metric ;
    dev:onAttribute common:hasRateState ;
    dev:hasValue common:Low .

# ── IMPLIED CONDITIONS ───────────────────────────────────────────────

:Cond_ElectricHeartRateProperty_RateState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: ElectricHeartRate_Property hasRateState Low" ;
    rdfs:comment "The electric heart rate physiological property is low — the ECG-derived cardiac electrical depolarisation frequency is below threshold (bradycardia). Ontological translation of the device-level metric to the clinical property :ElectricHeartRate_Property." ;
    dev:aboutEntity :ElectricHeartRate_Property ;
    dev:onAttribute common:hasRateState ;
    dev:hasValue common:Low .

:Cond_CardiacContractionProcess_FunctionalState_Hypo
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Cardiac_Contraction_Process hasFunctionalState Hypo" ;
    rdfs:comment "The cardiac contraction process is hypofunctional — the heart rate is below threshold (bradycardia). Inferred from low electric heart rate: the cardiac rate-generating process is underactive." ;
    dev:aboutEntity :Cardiac_Contraction_Process ;
    dev:onAttribute clin:hasFunctionalState ;
    dev:hasValue common:Hypo .

:Cond_CardiacContraction_FunctionalState_Hypo
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Cardiac_Contraction_Process hasFunctionalState Hypo" ;
    rdfs:comment "Name variant of :Cond_CardiacContractionProcess_FunctionalState_Hypo used in earlier alarms referencing the shorter 'Contraction' suffix. Same semantics: cardiac contraction process is hypofunctional (bradycardia)." ;
    dev:aboutEntity :Cardiac_Contraction_Process ;
    dev:onAttribute clin:hasFunctionalState ;
    dev:hasValue common:Hypo .


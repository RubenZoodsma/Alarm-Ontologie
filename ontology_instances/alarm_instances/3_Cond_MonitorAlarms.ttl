#######################################################################
# INFERRED CONDITIONS  
# Derived knowledge that logically follows from asserted conditions and network reasoning
#######################################################################

# Device Channel Conditions (Infrastructure)
:Cond_ABPDeviceChannel_FunctionalState_Enabled
    a dev:Condition ;
    rdfs:label "ABP Device Channel Enabled" ;
    rdfs:comment "Inferred: ABP device channel is enabled (from connected sensor)" ;
    dev:aboutEntity :ABP_Channel ;
    dev:onAttribute clin:hasState ;
    dev:hasValue common:Active .


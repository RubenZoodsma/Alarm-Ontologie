    rdfs:comment "Inferred: Patient has connected core temperature sensor" ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :CoreTemperature_Probe_Sensor .

:Cond_Patient_HasConnectedSensor_ECG

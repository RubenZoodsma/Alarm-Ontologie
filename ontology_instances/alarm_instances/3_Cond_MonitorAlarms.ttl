@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#######################################################################
# Ontology header
#######################################################################

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/alarm-conditions>
    a owl:Ontology ;
    rdfs:label "Alarm Condition Specifications" ;
    rdfs:comment "Defines individual Condition instances that represent specific requirements for alarm activation" .

#######################################################################
# CONDITION SPECIFICATIONS
# These define individual conditions referenced by AlertConditionDescription instances
# Organized by provenance: Asserted (explicit requirements) vs Inferred (derived knowledge)
#######################################################################


###################
# Condition blueprint:
## :<name of the condition instance>
##    a dev:AlertCondition , <specific condition type> ;
##    rdfs:label "<Human-readable label>" ;
##    rdfs:comment "<Detailed description of the condition and its clinical interpretation>" ;
##    dev:aboutEntity :<technical entity> ;
##    dev:onAttribute :<specific attribute of the entity> ;
##    dev:hasValue <specific value that the attribute must have for the condition to be true> .


#######################################################################
# ALARM 1 | PHILIPSMONITOR - ?? SpO2l hoog
# ALARM 2 | PHILIPSMONITOR - ?? SpO2po hoog
# (shared conditions listed once; alarm-specific conditions labelled)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_PhilipsMonitor_OperationalState_Enabled
    a dev:AlertCondition , dev:DeviceOperationalCondition ;
    rdfs:label "Condition: PhilipsMonitor hasOperationalState Enabled" ;
    rdfs:comment "The Philips Monitor is powered on and in an enabled/active operational state. Required by all Philips Monitor alarms." ;
    dev:aboutEntity :PhilipsMonitor ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_PulseOximetrySensor_OperationalState_Enabled
    a dev:AlertCondition , dev:SensorConnectivityCondition ;
    rdfs:label "Condition: PulseOximetrySensor hasOperationalState Enabled" ;
    rdfs:comment "The pulse oximetry sensor probe is physically connected and recognised by the monitor." ;
    dev:aboutEntity :Pulse_Oximeter_Sensor ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_SpO2Metric_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: SpO2Metric hasOperationalState Enabled" ;
    rdfs:comment "The SpO2 metric is actively being measured and its value is available for alarm evaluation." ;
    dev:aboutEntity :SpO2_Metric ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

## Alarm 1 specific — left-side probe placement
:Cond_PulseOximetrySensor_MeasurementLocation_LeftSide
    a dev:AlertCondition , dev:MeasurementLocationCondition ;
    rdfs:label "Condition: PulseOximetrySensor hasMeasurementSite LeftHand" ;
    rdfs:comment "The pulse oximetry sensor is placed on the left side (left hand). Mapped to :LeftHand — the closest defined MeasurementSite instance. Distinguishes SpO2l (left) from SpO2r (right) and SpO2po (post-ductal) measurements." ;
    dev:aboutEntity :Pulse_Oximeter_Sensor ;
    dev:onAttribute dev:hasMeasurementSite ;
    dev:hasValue :LeftSided .

## Alarm 2 specific — post-ductal probe placement
:Cond_PulseOximetrySensor_MeasurementLocation_postDuctal
    a dev:AlertCondition , dev:MeasurementLocationCondition ;
    rdfs:label "Condition: PulseOximetrySensor hasMeasurementSite PostDuctal" ;
    rdfs:comment "The pulse oximetry sensor is placed at a post-ductal site (e.g. left foot or umbilical area), enabling comparison with pre-ductal SpO2 for detection of ductal circulatory shunting." ;
    dev:aboutEntity :Pulse_Oximeter_Sensor ;
    dev:onAttribute dev:hasMeasurementSite ;
    dev:hasValue :PostDuctal .

:Cond_SpO2Metric_MagnitudeState_High
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: SpO2Metric hasMagnitudeState High" ;
    rdfs:comment "The SpO2 metric value is above the normal range (hyperoxaemia). Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :SpO2_Metric ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:High .

# ── IMPLIED / INFERRED CONDITIONS ────────────────────────────────────

:Cond_Patient_HasConnectedDevice_PhilipsMonitor
    a dev:AlertCondition , dev:PatientConnectivityCondition ;
    rdfs:label "Condition: Patient hasConnectedDevice PhilipsMonitor" ;
    rdfs:comment "Inferred from device being enabled: the patient is connected to (monitored by) the Philips Monitor. Property clin:hasConnectedDevice is the intended cross-domain link from Patient to PhysicalDevice." ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedDevice ;
    dev:hasValue :PhilipsMonitor .

:Cond_Patient_HasConnectedSensor_PulseOximetry
    a dev:AlertCondition , dev:PatientConnectivityCondition ;
    rdfs:label "Condition: Patient hasConnectedSensor PulseOximetrySensor" ;
    rdfs:comment "Inferred from sensor connectivity: the patient has a pulse oximetry probe applied. Property clin:hasConnectedSensor is the intended cross-domain link from Patient to Sensor." ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :Pulse_Oximeter_Sensor .

:Cond_SaO2Property_ObservationState_Monitored
    a dev:AlertCondition , dev:ObservationStateCondition ;
    rdfs:label "Condition: Arterial_Oxygenation_Property hasObservationState Monitored" ;
    rdfs:comment "Inferred from SpO2 metric availability: the clinical arterial oxygenation property (SaO2) is being actively observed. Triggers upward propagation of Monitored to the parent process and organ via property chain axioms." ;
    dev:aboutEntity :Arterial_Oxygenation_Property ;
    dev:onAttribute clin:hasObservationState ;
    dev:hasValue common:Monitored .

:Cond_SaO2Property_MagnitudeState_High
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Arterial_Oxygenation_Property hasMagnitudeState High" ;
    rdfs:comment "Ontological interpretation of the SpO2 metric being high: the clinical SaO2 physiological property is in an elevated state. Represents hyperoxaemia at the clinical property level." ;
    dev:aboutEntity :Arterial_Oxygenation_Property ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:High .

:Cond_PulmonaryOxygenation_FunctionalState_Hyper
    a dev:AlertCondition ;
    rdfs:label "Condition: Pulmonary_Oxygenation_Process hasFunctionalState Hyper" ;
    rdfs:comment "Inferred from elevated SaO2: the pulmonary oxygenation process is in a hyperfunctional state (excessive oxygenation)." ;
    dev:aboutEntity :Pulmonary_Oxygenation_Process ;
    dev:onAttribute clin:hasFunctionalState ;
    dev:hasValue common:Hyper .


#######################################################################
# ALARM 3 | PHILIPSMONITOR - ?? ST-II laag
# ALARM 4 | PHILIPSMONITOR - ?? ST-V hoog g
# (PhilipsMonitor/Patient-device conditions shared with above)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_ECGSensorGroup_OperationalState_Enabled
    a dev:AlertCondition , dev:SensorConnectivityCondition ;
    rdfs:label "Condition: ECG_SensorGroup hasOperationalState Enabled" ;
    rdfs:comment "The ECG sensor group (aggregating all ECG lead electrodes) is connected and functional. Represented by :ECG_SensorGroup, the SensorGroup that groups all ECG leads." ;
    dev:aboutEntity :ECG_SensorGroup ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

## Alarm 3 specific — ST-II metric
:Cond_STII_Metric_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: ST_II_Metric hasOperationalState Enabled" ;
    rdfs:comment "The ST-II metric (ST-segment deviation in lead II) is actively being calculated and its value is available." ;
    dev:aboutEntity :ST_II_Metric ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_STII_Metric_MagnitudeState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: ST_II_Metric hasMagnitudeState Low" ;
    rdfs:comment "The ST-II metric value is below the normal range (ST-segment depression in lead II). Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :ST_II_Metric ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:Low .

## Alarm 4 specific — ST-V metric
:Cond_STV_Metric_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: ST_V_Metric hasOperationalState Enabled" ;
    rdfs:comment "The ST-V metric (ST-segment deviation in lead V) is actively being calculated and its value is available." ;
    dev:aboutEntity :ST_V_Metric ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_STV_Metric_MagnitudeState_High
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: ST_V_Metric hasMagnitudeState High" ;
    rdfs:comment "The ST-V metric value is above the normal range (ST-segment elevation in lead V). Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :ST_V_Metric ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:High .

# ── IMPLIED / INFERRED CONDITIONS ────────────────────────────────────

:Cond_Patient_HasConnectedSensor_ECGSensor
    a dev:AlertCondition , dev:PatientConnectivityCondition ;
    rdfs:label "Condition: Patient hasConnectedSensor ECG_SensorGroup" ;
    rdfs:comment "Inferred from ECG sensor connectivity: the patient has ECG electrodes applied. Represented as the ECG_SensorGroup rather than individual leads." ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :ECG_SensorGroup .

:Cond_CardiacDepolarizationProperty_ObservationState_Monitored
    a dev:AlertCondition , dev:ObservationStateCondition ;
    rdfs:label "Condition: Cardiac_Electrical_Depolarization_Property hasObservationState Monitored" ;
    rdfs:comment "Inferred from ST metric availability: the cardiac electrical depolarisation property is being actively observed via ST-segment analysis." ;
    dev:aboutEntity :Cardiac_Electrical_Depolarization_Property ;
    dev:onAttribute clin:hasObservationState ;
    dev:hasValue common:Monitored .

## Alarm 3 specific — ST-II low → depolarisation low
:Cond_CardiacDepolarizationProperty_MagnitudeState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Cardiac_Electrical_Depolarization_Property hasMagnitudeState Low" ;
    rdfs:comment "Ontological interpretation of ST-II being low: the cardiac depolarisation property is in a low/deviant state (ST-segment depression). Note: interpretation of a single-lead deviation is clinically limited; process-level inference is intentionally withheld." ;
    dev:aboutEntity :Cardiac_Electrical_Depolarization_Property ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:Low .

## Alarm 4 specific — ST-V high → depolarisation high
:Cond_CardiacDepolarizationProperty_MagnitudeState_High
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Cardiac_Electrical_Depolarization_Property hasMagnitudeState High" ;
    rdfs:comment "Ontological interpretation of ST-V being high: the cardiac depolarisation property is in a high/deviant state (ST-segment elevation). Note: interpretation of a single-lead deviation is clinically limited; process-level inference is intentionally withheld." ;
    dev:aboutEntity :Cardiac_Electrical_Depolarization_Property ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:High .


#######################################################################
# ALARM 5 | PHILIPSMONITOR - ?? Thuid laag  (skin temperature low)
# (PhilipsMonitor/Patient-device conditions shared with above)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_SkinTemperatureSensor_OperationalState_Enabled
    a dev:AlertCondition , dev:SensorConnectivityCondition ;
    rdfs:label "Condition: SkinTemperature_Probe_Sensor hasOperationalState Enabled" ;
    rdfs:comment "The skin temperature probe is physically connected and recognised by the monitor." ;
    dev:aboutEntity :SkinTemperature_Probe_Sensor ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_SkinTempMetric_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: Skin_Temp_Metric hasOperationalState Enabled" ;
    rdfs:comment "The skin temperature metric is actively being measured and its value is available for alarm evaluation." ;
    dev:aboutEntity :Skin_Temp_Metric ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_SkinTempMetric_MagnitudeState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Skin_Temp_Metric hasMagnitudeState Low" ;
    rdfs:comment "The skin temperature metric value is below the normal range (hypothermic skin temperature). Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :Skin_Temp_Metric ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:Low .

# ── IMPLIED / INFERRED CONDITIONS ────────────────────────────────────

:Cond_Patient_HasConnectedSensor_SkinTempSensor
    a dev:AlertCondition , dev:PatientConnectivityCondition ;
    rdfs:label "Condition: Patient hasConnectedSensor SkinTemperature_Probe_Sensor" ;
    rdfs:comment "Inferred from sensor connectivity: the patient has a skin temperature probe applied." ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :SkinTemperature_Probe_Sensor .

:Cond_SkinTemperatureProperty_ObservationState_Monitored
    a dev:AlertCondition , dev:ObservationStateCondition ;
    rdfs:label "Condition: Temperature_Skin_Property hasObservationState Monitored" ;
    rdfs:comment "Inferred from skin temperature metric availability: the clinical skin temperature physiological property is being actively observed." ;
    dev:aboutEntity :Temperature_Skin_Property ;
    dev:onAttribute clin:hasObservationState ;
    dev:hasValue common:Monitored .

:Cond_SkinTemperatureProperty_MagnitudeState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Temperature_Skin_Property hasMagnitudeState Low" ;
    rdfs:comment "Ontological interpretation of the skin temperature metric being low: the clinical skin temperature physiological property is in a low/deviant state." ;
    dev:aboutEntity :Temperature_Skin_Property ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:Low .

:Cond_CutaneousThermoregulation_FunctionalState_Hypo
    a dev:AlertCondition ;
    rdfs:label "Condition: Thermoregulation_Process hasFunctionalState Hypo" ;
    rdfs:comment "Inferred from low skin temperature: the thermoregulation process is in a hypofunctional state (insufficient cutaneous thermal regulation). Note: mapped to :Thermoregulation_Process as no separate cutaneous sub-process instance exists." ;
    dev:aboutEntity :Thermoregulation_Process ;
    dev:onAttribute clin:hasFunctionalState ;
    dev:hasValue common:Hypo .


#######################################################################
# ALARM 6 | PHILIPSMONITOR - ?? Tkern hoog  (core temperature high)
# (PhilipsMonitor/Patient-device conditions shared with above)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_CoreTemperatureSensor_OperationalState_Enabled
    a dev:AlertCondition , dev:SensorConnectivityCondition ;
    rdfs:label "Condition: CoreTemperature_Probe_Sensor hasOperationalState Enabled" ;
    rdfs:comment "The core temperature probe is physically connected and recognised by the monitor." ;
    dev:aboutEntity :CoreTemperature_Probe_Sensor ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_CoreTempMetric_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: Core_Temp_Metric hasOperationalState Enabled" ;
    rdfs:comment "The core temperature metric is actively being measured and its value is available for alarm evaluation." ;
    dev:aboutEntity :Core_Temp_Metric ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_CoreTempMetric_MagnitudeState_High
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Core_Temp_Metric hasMagnitudeState High" ;
    rdfs:comment "The core temperature metric value is above the normal range (hyperthermia). Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :Core_Temp_Metric ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:High .

# ── IMPLIED / INFERRED CONDITIONS ────────────────────────────────────

:Cond_Patient_HasConnectedSensor_CoreTempSensor
    a dev:AlertCondition , dev:PatientConnectivityCondition ;
    rdfs:label "Condition: Patient hasConnectedSensor CoreTemperature_Probe_Sensor" ;
    rdfs:comment "Inferred from sensor connectivity: the patient has a core temperature probe applied." ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :CoreTemperature_Probe_Sensor .

:Cond_CoreTemperatureProperty_ObservationState_Monitored
    a dev:AlertCondition , dev:ObservationStateCondition ;
    rdfs:label "Condition: Temperature_Core_Property hasObservationState Monitored" ;
    rdfs:comment "Inferred from core temperature metric availability: the clinical core temperature physiological property is being actively observed." ;
    dev:aboutEntity :Temperature_Core_Property ;
    dev:onAttribute clin:hasObservationState ;
    dev:hasValue common:Monitored .

:Cond_CoreTemperatureProperty_MagnitudeState_High
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Temperature_Core_Property hasMagnitudeState High" ;
    rdfs:comment "Ontological interpretation of the core temperature metric being high: the clinical core temperature physiological property is in an elevated state (hyperthermia)." ;
    dev:aboutEntity :Temperature_Core_Property ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:High .

:Cond_CoreThermoRegulation_FunctionalState_Hyper
    a dev:AlertCondition ;
    rdfs:label "Condition: Thermoregulation_Process hasFunctionalState Hyper" ;
    rdfs:comment "Inferred from high core temperature: the thermoregulation process is in a hyperfunctional state (excessive heat production or insufficient heat dissipation). Note: mapped to :Thermoregulation_Process as no separate core sub-process instance exists." ;
    dev:aboutEntity :Thermoregulation_Process ;
    dev:onAttribute clin:hasFunctionalState ;
    dev:hasValue common:Hyper .


#######################################################################
# ALARM 7 | PHILIPSMONITOR - ??? Brady (pols)  (bradycardia - low pulse rate)
# (PhilipsMonitor/PulseOximetrySensor/Patient-device conditions shared with above)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_PulseRateMetric_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: PulsatileHeartRate_Metric hasOperationalState Enabled" ;
    rdfs:comment "The pulse rate metric (derived from pulse oximetry) is actively being measured and its value is available for alarm evaluation." ;
    dev:aboutEntity :PulsatileHeartRate_Metric ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_PulseRateMetric_RateState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: PulsatileHeartRate_Metric hasRateState Low" ;
    rdfs:comment "The pulse rate metric value is below the normal range (bradycardia). Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :PulsatileHeartRate_Metric ;
    dev:onAttribute common:hasRateState ;
    dev:hasValue common:Low .

# ── IMPLIED / INFERRED CONDITIONS ────────────────────────────────────

:Cond_PulsatileHeartRateProperty_ObservationState_Monitored
    a dev:AlertCondition , dev:ObservationStateCondition ;
    rdfs:label "Condition: Cardiac_Contractile_Frequency_Property hasObservationState Monitored" ;
    rdfs:comment "Inferred from pulse rate metric availability: the clinical pulsatile heart rate property (cardiac contractile frequency) is being actively observed." ;
    dev:aboutEntity :Cardiac_Contractile_Frequency_Property ;
    dev:onAttribute clin:hasObservationState ;
    dev:hasValue common:Monitored .

:Cond_PulsatileHeartRateProperty_RateState_low
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: Cardiac_Contractile_Frequency_Property hasRateState Low" ;
    rdfs:comment "Ontological interpretation of the pulse rate metric being low: the clinical pulsatile heart rate property is in a low/deviant state (bradycardia)." ;
    dev:aboutEntity :Cardiac_Contractile_Frequency_Property ;
    dev:onAttribute common:hasRateState ;
    dev:hasValue common:Low .

:Cond_CardiacRateProcess_FunctionalState_Hypo
    a dev:AlertCondition ;
    rdfs:label "Condition: Cardiac_Rate_Process hasFunctionalState Hypo" ;
    rdfs:comment "Inferred from low pulse rate: the cardiac rate process is in a hypofunctional state (insufficient contractile frequency — bradycardia). Mapped to :Cardiac_Rate_Process; consider :Cardiac_Contraction_Process for contraction-specific inferrals." ;
    dev:aboutEntity :Cardiac_Rate_Process ;
    dev:onAttribute clin:hasFunctionalState ;
    dev:hasValue common:Hypo .


#######################################################################
# ALARM 8 | PHILIPSMONITOR - ABP slecht signaal  (ABP poor signal quality — technical)
# ALARM 9 | PHILIPSMONITOR - ABPm hoog  (ABP mean high)
# (PhilipsMonitor/Patient-device conditions shared with above)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_ArterialBloodPressureSensor_OperationalState_Enabled
    a dev:AlertCondition , dev:SensorConnectivityCondition ;
    rdfs:label "Condition: ABP_Transducer_Sensor hasOperationalState Enabled" ;
    rdfs:comment "The arterial blood pressure transducer is physically connected and recognised by the monitor." ;
    dev:aboutEntity :ABP_Transducer_Sensor ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_ABPMetricGroup_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: ABP_MetricGroup hasOperationalState Enabled" ;
    rdfs:comment "The ABP metric group (covering systolic, diastolic, and mean ABP metrics) is actively being measured. Enables transitive linking to individual ABP metric components." ;
    dev:aboutEntity :ABP_MetricGroup ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

## Alarm 8 specific — signal quality insufficient
:Cond_ABP_Signal_QualityState_Insufficient
    a dev:AlertCondition , dev:SignalQualityCondition ;
    rdfs:label "Condition: ABP_Waveform_Signal hasQualityIndicator Insufficient" ;
    rdfs:comment "The ABP waveform signal quality is insufficient for reliable measurement. Device-side epistemic representation of the alarm trigger. NOTE: dev:hasValue references common:Insufficient — a signal quality state individual to be defined in alarmOnto_common.ttl." ;
    dev:aboutEntity :ABP_Waveform_Signal ;
    dev:onAttribute common:hasQualityIndicator ;
    dev:hasValue common:Insufficient .

## Alarm 9 specific — ABP mean metric high
:Cond_ABPMean_Metric_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: ABP_Mean_Metric hasOperationalState Enabled" ;
    rdfs:comment "The ABP mean metric is actively being measured and its value is available for alarm evaluation." ;
    dev:aboutEntity :ABP_Mean_Metric ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_ABPMean_Metric_MagnitudeState_High
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: ABP_Mean_Metric hasMagnitudeState High" ;
    rdfs:comment "The ABP mean metric value is above the normal range (hypertension). Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :ABP_Mean_Metric ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:High .

# ── IMPLIED / INFERRED CONDITIONS ────────────────────────────────────

:Cond_Patient_HasConnectedSensor_ABPtransducer
    a dev:AlertCondition , dev:PatientConnectivityCondition ;
    rdfs:label "Condition: Patient hasConnectedSensor ABP_Transducer_Sensor" ;
    rdfs:comment "Inferred from sensor connectivity: the patient has an arterial blood pressure transducer applied (intra-arterial catheter)." ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :ABP_Transducer_Sensor .

:Cond_ArterialBloodPressureProperty_ObservationState_Monitored
    a dev:AlertCondition , dev:ObservationStateCondition ;
    rdfs:label "Condition: ABP_Mean_Property hasObservationState Monitored" ;
    rdfs:comment "Inferred from ABP metric group availability: arterial blood pressure is being actively observed. Linked to :ABP_Mean_Property as the representative individual; ideally a composite ABP property group would be used." ;
    dev:aboutEntity :ABP_Mean_Property ;
    dev:onAttribute clin:hasObservationState ;
    dev:hasValue common:Monitored .

:Cond_ArterialBloodPressureMeanProperty_MagnitudeState_High
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: ABP_Mean_Property hasMagnitudeState High" ;
    rdfs:comment "Ontological interpretation of the ABP mean metric being high: the clinical ABP mean physiological property is in an elevated state (hypertension)." ;
    dev:aboutEntity :ABP_Mean_Property ;
    dev:onAttribute common:hasMagnitudeState ;
    dev:hasValue common:High .

:Cond_ArterialPressureRegulation_FunctionalState_Hyper
    a dev:AlertCondition ;
    rdfs:label "Condition: Arterial_Perfusion_Process hasFunctionalState Hyper" ;
    rdfs:comment "Inferred from elevated ABP mean: the arterial perfusion process is in a hyperfunctional state (excessive arterial pressure — hypertension). Mapped to :Arterial_Perfusion_Process as the closest available process instance." ;
    dev:aboutEntity :Arterial_Perfusion_Process ;
    dev:onAttribute clin:hasFunctionalState ;
    dev:hasValue common:Hyper .


#######################################################################
# ALARM 10 | PHILIPSMONITOR - BATTERY LOW  (technical)
# (PhilipsMonitor/Patient-device conditions shared with above)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_BatteryFunctionalUnit_OperationalState_Enabled
    a dev:AlertCondition , dev:DeviceOperationalCondition ;
    rdfs:label "Condition: Battery_Module hasOperationalState Enabled" ;
    rdfs:comment "The monitor's battery functional unit is operational (device is running on battery power). Required for the battery low alarm to be evaluable." ;
    dev:aboutEntity :Battery_Module ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_BatteryFunctionalUnit_PowerState_Low
    a dev:AlertCondition , dev:PowerStateCondition ;
    rdfs:label "Condition: Battery_Module hasPowerState Low" ;
    rdfs:comment "The battery module's power level is low (charge below operational threshold). Uses dev:hasPowerState with common:Low as the magnitude value. NOTE: dev:hasPowerState should be defined in alarmOnto_device.ttl." ;
    dev:aboutEntity :Battery_Module ;
    dev:onAttribute dev:hasPowerState ;
    dev:hasValue common:Low .



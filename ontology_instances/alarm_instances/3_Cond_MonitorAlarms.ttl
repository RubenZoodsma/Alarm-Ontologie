    dev:hasValue common:Error .


#######################################################################
# ALARM 34 | PHILIPSMONITOR - CO2 auto nulling  (capnography auto-calibration)
# ALARM 35 | PHILIPSMONITOR - CO2 ctr adapter er  (capnography adapter error)
# (PhilipsMonitor/Capnography/Ventilator/Patient conditions shared with alarm 14)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_CO2Metric_OperationalState_Enabled
    a dev:AlertCondition , dev:MetricAvailabilityCondition ;
    rdfs:label "Condition: CO2_MetricGroup hasOperationalState Enabled" ;
    rdfs:comment "At least one CO2 metric (EtCO2 or tcpCO2) is actively being measured. Represented by :CO2_MetricGroup — links transitively to :EtCO2_Metric and :tcpCO2_Metric." ;
    dev:aboutEntity :CO2_MetricGroup ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Enabled .

:Cond_CapnoSignal_qualityState_calibrating
    a dev:AlertCondition , dev:SignalQualityCondition ;
    rdfs:label "Condition: Capno_Waveform_Signal hasQualityIndicator Calibrating" ;
    rdfs:comment "The capnography waveform signal is temporarily unavailable because the sensor is performing an automatic baseline nulling/calibration. A transient signal quality state that resolves when calibration completes." ;
    dev:aboutEntity :Capno_Waveform_Signal ;
    dev:onAttribute common:hasQualityIndicator ;
    dev:hasValue common:Calibrating .

:Cond_CapnographySensor_FunctionalState_Malfunction
    a dev:AlertCondition , dev:SensorConnectivityCondition ;
    rdfs:label "Condition: Capnography_Sensor hasOperationalState Fault" ;
    rdfs:comment "The capnography sensor adapter has failed or is missing — the monitor cannot communicate with the CO2 measurement module (e.g. broken airway adapter, incompatible adapter type). Represented as dev:hasOperationalState common:Fault." ;
    dev:aboutEntity :Capnography_Sensor ;
    dev:onAttribute dev:hasOperationalState ;
    dev:hasValue common:Fault .


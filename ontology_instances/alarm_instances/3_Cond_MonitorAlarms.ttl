    dev:hasValue common:Enabled .

:Cond_RespRateMetric_RateState_absent
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: RespiratoryRate_Metric hasRateState Absent" ;
    rdfs:comment "The respiratory rate metric shows no detectable respiratory cycles — apnea. Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :RespiratoryRate_Metric ;
    dev:onAttribute common:hasRateState ;
    dev:hasValue common:Absent .

:Cond_ElectricHeartRateMetric_RateState_absent
    a dev:AlertCondition , dev:PhysiologicalValueCondition ;
    rdfs:label "Condition: ElectricHeartRate_Metric hasRateState Absent" ;
    rdfs:comment "The ECG-derived heart rate metric shows no detectable electrical depolarisation events — asystole. Device-side epistemic representation of the alarm trigger." ;
    dev:aboutEntity :ElectricHeartRate_Metric ;
    dev:onAttribute common:hasRateState ;
    dev:hasValue common:Absent .


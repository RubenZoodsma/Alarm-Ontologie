    rdfs:label "Patient Connected ECG" ;
    rdfs:comment "Inferred: Patient has connected ECG sensors" ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :ECG_RA_Sensor, :ECG_LA_Sensor, :ECG_LL_Sensor, :ECG_RL_Sensor, :ECG_V1_Sensor, :ECG_V2_Sensor, :ECG_V3_Sensor, :ECG_V4_Sensor, :ECG_V5_Sensor, :ECG_V6_Sensor .

:Cond_Patient_HasConnectedSensor_PulseOximetry
    a dev:Condition ;
    rdfs:label "Patient Connected Pulse Oximetry" ;
    rdfs:comment "Inferred: Patient has connected pulse oximetry sensor" ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :Pulse_Oximeter_Sensor .

:Cond_Patient_HasConnectedSensor_SkinTempSensor
    a dev:Condition ;
    rdfs:label "Patient Connected Skin Temperature" ;
    rdfs:comment "Inferred: Patient has connected skin temperature sensor" ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :SkinTemperature_Probe_Sensor .


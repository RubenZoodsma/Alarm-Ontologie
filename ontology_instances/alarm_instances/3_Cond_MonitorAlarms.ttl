#######################################################################
# ALARM 22 | PHILIPSMONITOR - ABP artefact  (ABP signal artefact — technical)
# ALARM 23 | PHILIPSMONITOR - ABP buiten bereik  (ABP out of range — technical)
# ALARM 24 | PHILIPSMONITOR - ABP contr.nulling  (ABP nulling error — technical)
# (PhilipsMonitor/ABPSensor/ABPMetricGroup/Patient conditions shared with alarms 8-9)
#######################################################################

# ── ASSERTED CONDITIONS ──────────────────────────────────────────────

:Cond_ABP_Signal_QualityState_Artefact
    a dev:AlertCondition , dev:SignalQualityCondition ;
    rdfs:label "Condition: ABP_Waveform_Signal hasQualityIndicator Artefact" ;
    rdfs:comment "The ABP waveform signal is contaminated by a motion or electrical artefact — a sub-type of insufficient quality. The waveform does not reflect true arterial pressure." ;
    dev:aboutEntity :ABP_Waveform_Signal ;
    dev:onAttribute common:hasQualityIndicator ;
    dev:hasValue common:Artefact .

:Cond_ABP_Signal_QualityState_outOfRange
    a dev:AlertCondition , dev:SignalQualityCondition ;
    rdfs:label "Condition: ABP_Waveform_Signal hasQualityIndicator OutOfRange" ;
    rdfs:comment "The ABP waveform signal value is outside the measurable range of the transducer — a sub-type of insufficient quality. Common cause: kinked line, positional change exceeding offset range, or extreme pressure." ;
    dev:aboutEntity :ABP_Waveform_Signal ;
    dev:onAttribute common:hasQualityIndicator ;
    dev:hasValue common:OutOfRange .

:Cond_ABP_Signal_QualityState_nullingError
    a dev:AlertCondition , dev:SignalQualityCondition ;
    rdfs:label "Condition: ABP_Waveform_Signal hasQualityIndicator NullingError" ;
    rdfs:comment "The ABP transducer has not been properly zeroed/nulled — a sub-type of insufficient quality. The measured values are offset by the residual reference pressure." ;
    dev:aboutEntity :ABP_Waveform_Signal ;
    dev:onAttribute common:hasQualityIndicator ;
    dev:hasValue common:NullingError .


#######################################################################

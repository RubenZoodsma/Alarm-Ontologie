# Patient-Device Connection Conditions (Clinical Network)
:Cond_Patient_HasConnectedDevice_PhilipsMonitor
    a dev:Condition ;
    rdfs:label "Patient Connected to Philips Monitor" ;
    rdfs:comment "Inferred: Patient has connected Philips Monitor device" ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedDevice ;
    dev:hasValue :PhilipsMonitor .

:Cond_Patient_HasConnectedDevice_Ventilator
    a dev:Condition ;
    rdfs:label "Patient Connected to Ventilator" ;
    rdfs:comment "Inferred: Patient has connected ventilator device" ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedDevice ;
    dev:hasValue :VentilatorDevice .

# Patient-Sensor Connection Conditions
:Cond_Patient_HasConnectedSensor_ABPtransducer
    a dev:Condition ;
    rdfs:label "Patient Connected ABP Transducer" ;
    rdfs:comment "Inferred: Patient has connected ABP transducer sensor" ;
    dev:aboutEntity :Patient ;
    dev:onAttribute clin:hasConnectedSensor ;
    dev:hasValue :ABP_Transducer_Sensor .

:Cond_Patient_HasConnectedSensor_Capnography
    a dev:Condition ;
    rdfs:label "Patient Connected Capnography" ;
    rdfs:comment "Inferred: Patient has connected capnography sensor" ;

@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#######################################################################
# Ontology header
#######################################################################

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/instances/alarm-conditions>
    a owl:Ontology ;
    rdfs:label "Alarm Condition Specifications" ;
    rdfs:comment "Defines individual Condition instances that represent specific requirements for alarm activation" .

#######################################################################
# CONDITION SPECIFICATIONS
# These define individual conditions referenced by AlertConditionDescription instances
# Organized by provenance: Asserted (explicit requirements) vs Inferred (derived knowledge)
#######################################################################

#######################################################################
# ASSERTED CONDITIONS
# Explicit entity-attribute-value requirements for alarm activation
#######################################################################

# ABP (Arterial Blood Pressure) Conditions
:Cond_ABPMean_Metric_AvailabilityState_Available
    a dev:Condition ;
    rdfs:label "ABP Mean Metric Available" ;
    rdfs:comment "Condition: ABP Mean metric is being measured and available" ;
    dev:aboutEntity :ABP_Mean_Metric ;
    dev:onAttribute dev:hasAvailabilityState ;
    dev:hasValue common:MetricAvailable .

:Cond_ABPMean_Metric_ValueInterpretation_HighLimitViolation
    a dev:Condition ;
    rdfs:label "ABP Mean High Limit Violation" ;
    rdfs:comment "Condition: ABP Mean metric value exceeds high threshold" ;
    dev:aboutEntity :ABP_Mean_Metric ;
    dev:onAttribute dev:hasValueInterpretation ;
    dev:hasValue common:HighLimitViolation .

:Cond_ABP_Signal_QualityState_Insufficient
    a dev:Condition ;
    rdfs:label "ABP Signal Quality Insufficient" ;
    rdfs:comment "Condition: ABP signal quality is insufficient for reliable measurements" ;
    dev:aboutEntity :ABP_Waveform_Signal ;
    dev:onAttribute dev:hasQualityState ;
    dev:hasValue :Insufficient .

:Cond_ArterialBloodPressureSensor_FunctionalState_Connected
    a dev:Condition ;
    rdfs:label "ABP Sensor Connected" ;
    rdfs:comment "Condition: Arterial blood pressure sensor is connected" ;
    dev:aboutEntity :ABP_Transducer_Sensor ;
    dev:onAttribute clin:hasState ;
    dev:hasValue common:Connected .

# Battery Conditions
:Cond_BatteryFunctionalUnit_FunctionalState_Enabled
    a dev:Condition ;
    rdfs:label "Battery Unit Enabled" ;
    rdfs:comment "Condition: Battery functional unit is enabled" ;
    dev:aboutEntity :Battery_Module ;
    dev:onAttribute clin:hasState ;
    dev:hasValue common:Active .

:Cond_BatteryFunctionalUnit_PowerState_Low
    a dev:Condition ;
    rdfs:label "Battery Power Low" ;
    rdfs:comment "Condition: Battery functional unit power level is low" ;
    dev:aboutEntity :Battery_Module ;
    dev:onAttribute dev:hasPowerState ;
    dev:hasValue :Low .


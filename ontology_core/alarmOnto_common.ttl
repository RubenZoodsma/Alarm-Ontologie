@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# ONTOLOGY HEADER
#################################################################

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common>
    a owl:Ontology ;
    rdfs:label "Alarm Ontology - Common/Shared Module" ;
    rdfs:comment "Shared base classes and properties used by both clinical and device modules" .



#################################################################
# TOP-LEVEL / SHARED CLASSES
#################################################################

:Entity a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Abstract superclass for all device and clinical entities." .

:State a owl:Class ;
    rdfs:label "State" ;
    rdfs:comment "Abstract placeholder for state/value-like entities (Enabled, Impaired, etc.). Instances can be introduced in an ABox." .

#################################################################
# CROSS-DOMAIN PROPERTIES
#################################################################

:measuresProperty a owl:ObjectProperty ;
    rdfs:domain dev:Metric ;
    rdfs:range clin:PhysiologicalProperty ;
    rdfs:label "measures property" ;
    rdfs:comment "Device metric measures a clinical/physiological property." .

:measuredByMetric a owl:ObjectProperty ;
    rdfs:domain clin:PhysiologicalProperty ;
    rdfs:range dev:Metric ;
    rdfs:label "measured by metric" ;
    rdfs:comment "Inverse link: physiological property is measured by a device metric." .

#################################################################
# DATA PROPERTIES (SHARED)
#################################################################

:hasState a owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "has state" ;
    rdfs:comment "Generic state marker (e.g. Enabled, Impaired, Active)." .

:hasStateInstance a owl:ObjectProperty ;
    rdfs:domain :Entity ;
    rdfs:range :State ;
    rdfs:label "has state instance" ;
    rdfs:comment "Links an entity to a specific state individual from the state vocabulary." .

:hasActivationState a owl:DatatypeProperty ;
    rdfs:domain dev:Metric ;
    rdfs:range xsd:string ;
    rdfs:label "has activation state" ;
    rdfs:comment "Device-style activation state, e.g. On, Standby, Off." .

:hasAvailabilityStatus a owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "has availability status" ;
    rdfs:comment "Indicates if data/value is available." .

:hasQualityIndicator a owl:DatatypeProperty ;
    rdfs:domain dev:Signal ;
    rdfs:range xsd:string ;
    rdfs:label "has quality indicator" ;
    rdfs:comment "Quality of a signal (e.g. Good, Bad, Questionable)." .

:hasValue a owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:decimal ;
    rdfs:label "has value" ;
    rdfs:comment "Numeric value for metrics or physiological properties." .

:hasUnit a owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "has unit" .

:hasRange a owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "has range" .

:hasSNOMEDCode a owl:DatatypeProperty ;
    rdfs:domain clin:ClinicalEntity ;
    rdfs:range xsd:string ;
    rdfs:label "has SNOMED code" .

:hasMDCCode a owl:DatatypeProperty ;
    rdfs:domain dev:DeviceEntity ;
    rdfs:range xsd:string ;
    rdfs:label "has MDC code" ;
    rdfs:comment "IEEE 11073/MDER code for device-side interoperability." .

#################################################################
# SHARED STATE VOCABULARY
#################################################################

# Operational States
:Enabled a :State ;
    rdfs:label "Enabled" ;
    rdfs:comment "Entity is operational and active." .

:Disabled a :State ;
    rdfs:label "Disabled" ;
    rdfs:comment "Entity is turned off or not operational." .

:Standby a :State ;
    rdfs:label "Standby" ;
    rdfs:comment "Entity is ready but not actively operating." .

:Fault a :State ;
    rdfs:label "Fault" ;
    rdfs:comment "Entity has detected an error condition." .

# Limit violation interpretations
:LowLimitViolation a :State ;
    rdfs:label "Low Limit Violation" ;
    rdfs:comment "Measured value is below the defined lower limit." .

:HighLimitViolation a :State ;
    rdfs:label "High Limit Violation" ;
    rdfs:comment "Measured value is above the defined upper limit." .

# Absent cycle interpretations
:ApneaInterpretation a :State ;
    rdfs:label "Apnea Interpretation" ;
    rdfs:comment "Absence of breathing cycles detected." .

:AsystoleInterpretation a :State ;
    rdfs:label "Asystole Interpretation" ;
    rdfs:comment "Absence of cardiac electrical activity detected." .

# Rhythm interpretations

:VentricularFibrillationInterpretation a :State ;
    rdfs:label "Ventricular Fibrillation Interpretation" ;
    rdfs:comment "Irregular and rapid heart rhythm detected." .

:VentricularTachycardiaInterpretation a :State ;
    rdfs:label "Ventricular Tachycardia Interpretation" ;
    rdfs:comment "Fast heart rhythm originating from the ventricles detected." .

# Rate interpretations
:BradycardiaInterpretation a :State ;
    rdfs:label "Bradycardia Interpretation" ;
    rdfs:comment "Heart rate below normal limits detected." .

:TachycardiaInterpretation a :State ;
    rdfs:label "Tachycardia Interpretation" ;
    rdfs:comment "Heart rate above normal limits detected." .

# Activity States
:Active a :State ;
    rdfs:label "Active" ;
    rdfs:comment "Currently active or triggered." .

:Inactive a :State ;
    rdfs:label "Inactive" ;
    rdfs:comment "Currently not active or dormant." .

# Connection States
:Connected a :State ;
    rdfs:label "Connected" ;
    rdfs:comment "Device or sensor is properly connected." .

:Disconnected a :State ;
    rdfs:label "Disconnected" ;
    rdfs:comment "Device or sensor is not connected." .

# Transmission States
:Transmitting a :State ;
    rdfs:label "Transmitting" ;
    rdfs:comment "Signal or data is being transmitted." .

# Metric availability states
:MetricAvailable a :State ;
    rdfs:label "Metric Available" ;
    rdfs:comment "Device is actively measuring or collecting data." .

# Monitoring States
:MonitoredState a :State ;
    rdfs:label "Monitored State" ;
    rdfs:comment "Entity is being actively monitored." .

:AlertSoundType a owl:Class ;
    rdfs:subClassOf dev:AlertEntity ;
    rdfs:label "Alert Sound Type" ;
    rdfs:comment "Defines different types of alert sounds for alarms." .

### Alarm-based object properties
:lowAlertSound a :AlertSoundType ;
    rdfs:label "Low Alert Sound" .

:mediumAlertSound a :AlertSoundType ;
    rdfs:label "Medium Alert Sound" .

:highAlertSound a :AlertSoundType ;
    rdfs:label "High Alert Sound" .

:AlertPriorityLevel a owl:Class ;
    rdfs:subClassOf dev:AlertEntity ;
    rdfs:label "Alert Priority Level" ;
    rdfs:comment "Defines priority levels for alerts/alarms." .


:lowPriority a :AlertPriorityLevel ;
    :hasSoundEffect :lowAlertSound ;
    :hasColourEffect "Blue" ;
    rdfs:label "Low Priority alarm" .

:mediumPriority a :AlertPriorityLevel ;
    :hasSoundEffect :mediumAlertSound ;
    :hasColourEffect "Yellow" ;
    rdfs:label "Medium Priority alarm" .

:highPriority a :AlertPriorityLevel ;
    :hasSoundEffect :highAlertSound ;
    :hasColourEffect "Red" ;
    rdfs:label "High Priority alarm" .

:AlertTypeGroup a owl:Class ;
    rdfs:subClassOf dev:AlertEntity ;
    rdfs:label "Alert Type Group" ;
    rdfs:comment "Defines groups/categories for alerts/alarms." .

:technicalAlarmGroup a :AlertTypeGroup ;
    rdfs:label "Technical Alarm Group" .

:physiologicalAlarmGroup a :AlertTypeGroup ;
    rdfs:label "Physiological Alarm Group" .


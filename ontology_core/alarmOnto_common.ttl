@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix clin: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix dev: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/device#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# ONTOLOGY HEADER
#################################################################

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common>
    a owl:Ontology ;
    rdfs:label "Alarm Ontology - Common/Shared Module" ;
    rdfs:comment "Shared base classes and properties used by both clinical and device modules" .



#################################################################
# TOP-LEVEL / SHARED CLASSES
#################################################################

:Entity a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Abstract superclass for all device and clinical entities." .

:State a owl:Class ;
    rdfs:label "State" ;
    rdfs:comment "Abstract placeholder for state/value-like entities (Enabled, Impaired, etc.). Instances can be introduced in an ABox." .

#################################################################
# CROSS-DOMAIN PROPERTIES
#################################################################

:measuresProperty a owl:ObjectProperty ;
    rdfs:domain dev:Metric ;
    rdfs:range clin:PhysiologicalProperty ;
    rdfs:label "measures property" ;
    rdfs:comment "Device metric measures a clinical/physiological property." .

:measuredByMetric a owl:ObjectProperty ;
    rdfs:domain clin:PhysiologicalProperty ;
    rdfs:range dev:Metric ;
    rdfs:label "measured by metric" ;
    rdfs:comment "Inverse link: physiological property is measured by a device metric." .

#################################################################
# DATA PROPERTIES (SHARED)
#################################################################

:hasMagnitudeState a owl:ObjectProperty ;
    rdfs:domain :Entity ;
    rdfs:range :State ;
    rdfs:label "has magnitude state" ;
    rdfs:comment "Indicates the magnitude/quantity state of a metric or physiological property (e.g. High, Low, Normal, Critical). Applies to both device metrics and clinical properties." .

:hasRateState a owl:ObjectProperty ;
    rdfs:domain :Entity ;
    rdfs:range :State ;
    rdfs:label "has rate state" ;
    rdfs:comment "Indicates the rate/frequency state of a metric or physiological property (e.g. High, Low, Normal). Applies to rate-type metrics such as heart rate or respiratory rate." .

:hasQualityIndicator a owl:ObjectProperty ;
    rdfs:domain dev:Signal ;
    rdfs:range :QualityState ;
    rdfs:label "has quality indicator" ;
    rdfs:comment "Quality of a signal expressed as a named QualityState individual (e.g. common:Sufficient, common:Insufficient). Changed from DatatypeProperty to ObjectProperty to align with the QualityState class and its individuals." .

:hasOperationalStatus a owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "has operational status" ;
    rdfs:comment "Operational status of an entity (e.g. Enabled, Disabled)." .

:hasFunctionalStatus a owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "has functional status" ;
    rdfs:comment "Functional status of an entity (e.g. Normal Function, Hyper, Hypo)." .

:hasObservationalStatus a owl:DatatypeProperty ;
    rdfs:domain :Entity ;
    rdfs:range xsd:string ;
    rdfs:label "has observational status" ;
    rdfs:comment "Observational status of an entity (e.g. Monitored, Not Monitored)." .

:hasSNOMEDCode a owl:DatatypeProperty ;
    rdfs:domain clin:ClinicalEntity ;
    rdfs:range xsd:string ;
    rdfs:label "has SNOMED code" .

:hasMDCCode a owl:DatatypeProperty ;
    rdfs:domain dev:DeviceEntity ;
    rdfs:range xsd:string ;
    rdfs:label "has MDC code" ;
    rdfs:comment "IEEE 11073/MDER code for device-side interoperability." .

#################################################################
# SHARED STATE VOCABULARY
#################################################################

:OperationalState a :State ;
    rdfs:label "Operational State" ;
    rdfs:comment "States related to the operational status of a device or entity (e.g. Enabled, Disabled, Connected)." .

# Operational States
:Enabled a :OperationalState ;
    rdfs:label "Enabled" ;
    rdfs:comment "Entity is operational and active." .

:Disabled a :OperationalState ;
    rdfs:label "Disabled" ;
    rdfs:comment "Entity is turned off or not operational." .

:Standby a :OperationalState ;
    rdfs:label "Standby" ;
    rdfs:comment "Entity is ready but not actively operating." .

:Fault a :OperationalState ;
    rdfs:label "Fault" ;
    rdfs:comment "Entity has detected an error condition." .

:Disconnected a :OperationalState ;
    rdfs:label "Disconnected" ;
    rdfs:comment "Entity (typically a sensor or device channel) is physically disconnected from the monitor or patient. Distinct from Disabled (software off) and Fault (error state)." .

:Error a :OperationalState ;
    rdfs:label "Error" ;
    rdfs:comment "Entity (typically a software module or device application) is in an error state due to a software or application fault. Distinct from Fault (hardware error) and Disconnected (physical absence)." .



:MagnitudeState a :State ;
    rdfs:label "Magnitude State" ;
    rdfs:comment "States indicating the magnitude or level of a measurement (e.g. High, Low, Normal)." .

:RateState a :State ;
    rdfs:label "Rate State" ;
    rdfs:comment "States indicating the rate or frequency of a measurement (e.g. High, Low, Normal)." .

# Magnitude states — primary semantic values for hasMagnitudeState
:VeryHigh a :MagnitudeState, :RateState ;
    rdfs:label "Very High" ;
    rdfs:comment "Value or level is significantly above the normal/reference range." .

:High a :MagnitudeState, :RateState ;
    rdfs:label "High" ;
    rdfs:comment "Value or level is above the normal/reference range." .

:Normal a :MagnitudeState, :RateState ;
    rdfs:label "Normal" ;
    rdfs:comment "Value or level is within the normal/reference range." .

:Low a :MagnitudeState, :RateState, :PowerState ;
    rdfs:label "Low" ;
    rdfs:comment "Value or level is below the normal/reference range." .

:VeryLow a :MagnitudeState, :RateState ;
    rdfs:label "Very Low" ;

    rdfs:comment "Value or level is significantly below the normal/reference range." .

:Absent a :RateState ;
    rdfs:label "Absent" ;
    rdfs:comment "Rate or signal is completely absent — no detectable events (e.g. no heartbeats, no respiratory cycles). Represents the most extreme low rate state, beyond VeryLow." .

:Abnormal a :MagnitudeState , :FunctionalState ;
    rdfs:label "Abnormal" ;
    rdfs:comment "Value or functional state deviates from the normal/reference range in an unspecified direction. Used when the alarm message does not distinguish between high and low deviation (e.g. 'HI/LO' alarms)." .

:PowerState a :MagnitudeState ;
    rdfs:label "Power State" ;
    rdfs:comment "States indicating the power status of a device (e.g. On, Off)." .


## Functional states - both for clinical and device-related functionality
:FunctionalState a :State ;
    rdfs:label "Functional State" ;
    rdfs:comment "States indicating the functional status of a process or entity (e.g. Active, Hyper, Hypo)." .

:CriticallyHypo a :FunctionalState ;
    rdfs:label "Critically Hypo" ;
    rdfs:comment "Process or entity is in a critically hypofunctional state (severely underactive/insufficient)." .

:Hypo a :FunctionalState ;
    rdfs:label "Hypo" ;
    rdfs:comment "Process or entity is in a hypofunctional state (underactive/insufficient)." .

:NormalFunction a :FunctionalState ;
    rdfs:label "Normal Function" ;
    rdfs:comment "Process or entity is functioning normally." .

:Hyper a :FunctionalState ;
    rdfs:label "Hyper" ;
    rdfs:comment "Process or entity is in a hyperfunctional state (overactive/excessive)." .

:CriticallyHyper a :FunctionalState ;
    rdfs:label "Critically Hyper" ;
    rdfs:comment "Process or entity is in a critically hyperfunctional state (severely overactive/excessive)." .

:Arrest a :FunctionalState ;
    rdfs:label "Arrest" ;
    rdfs:comment "Process has completely ceased — total absence of function (e.g. cardiac arrest, respiratory arrest/apnea). Represents the most extreme hypofunctional state, beyond CriticallyHypo." .

:RequiresVerification a :FunctionalState ;
    rdfs:label "Requires Verification" ;
    rdfs:comment "Entity (device, module, or configuration) is operational but has flagged a condition that requires manual verification or confirmation by the user before proceeding (e.g. changed settings, unconfirmed patient ID, SpeedPoint data mismatch)." .

:RequiresConfirmation a :FunctionalState ;
    rdfs:label "Requires Confirmation" ;
    rdfs:comment "Entity (record, module, or configuration) requires explicit user confirmation before proceeding — stronger than RequiresVerification in that the user must actively confirm (e.g. patient identity record after unit transfer, settings after reset)." .

:Silenced a :FunctionalState ;
    rdfs:label "Silenced" ;
    rdfs:comment "Alarms or alerts for this entity have been deliberately silenced/suspended by the user. The entity is still operational and measured, but alarm notifications have been turned off (e.g. ECG/arrhythmia alarms silenced)." .

:CheckSettings a :FunctionalState ;
    rdfs:label "Check Settings" ;
    rdfs:comment "Device or module is operational but has detected a configuration issue or mismatch that requires the user to inspect and correct settings (e.g. app.geg. = application data missing; connected device settings not received). Weaker than RequiresVerification: the device prompts a check rather than blocking operation." .


## monitoring states
:AvailableState a :State ;
    rdfs:label "Available State" ;
    rdfs:comment "Entity is available: actively monitored." .

# Monitoring states — primary semantic value for hasObservationState
:Monitored a :AvailableState ;
    rdfs:label "Monitored" ;
    rdfs:comment "Entity is being actively observed and measured." .

:NotMonitored a :AvailableState ;
    rdfs:label "Not Monitored" ;
    rdfs:comment "Entity is not being actively observed." .

:Available a :AvailableState ;
    rdfs:label "Available" ;
    rdfs:comment "Entity is available for monitoring or observation." .


## quality states
:QualityState a :State ;
    rdfs:label "Quality State" ;
    rdfs:comment "States indicating the quality of a signal or measurement (e.g. Good, Bad, Questionable)." .

:Insufficient a :QualityState ;
    rdfs:label "Insufficient Quality" ;
    rdfs:comment "Signal or measurement quality is insufficient for reliable interpretation." .

:Artefact a :QualityState ;
    rdfs:label "Artefact" ;
    rdfs:comment "Signal quality is degraded by a motion or electrical artefact — a sub-type of insufficient quality. The measured waveform does not reflect true physiological origin." .

:OutOfRange a :QualityState ;
    rdfs:label "Out of Range" ;
    rdfs:comment "Signal value is outside the measurable range of the sensor or transducer — a sub-type of insufficient quality. Common cause: catheter not zeroed, kinked line, or excessive pressure." .

:NullingError a :QualityState ;
    rdfs:label "Nulling Error" ;
    rdfs:comment "Signal quality is compromised due to an incomplete or failed zeroing/nulling of the transducer — a sub-type of insufficient quality. Specifically applies to invasive pressure sensors (e.g. ABP transducer)." .

:Calibrating a :QualityState ;
    rdfs:label "Calibrating" ;
    rdfs:comment "Signal is temporarily unavailable or unreliable because the sensor is performing an automatic calibration or baseline nulling procedure. A transient sub-type of insufficient quality that resolves when calibration completes (e.g. CO2 auto nulling)." .

:Noisy a :QualityState ;
    rdfs:label "Noisy" ;
    rdfs:comment "Signal quality is degraded by excessive noise, typically due to poor sensor contact, interference, or patient movement. The measured waveform is excessively noisy and may not be reliably interpreted." .






:AlertSoundType a owl:Class ;
    rdfs:subClassOf dev:AlertEntity ;
    rdfs:label "Alert Sound Type" ;
    rdfs:comment "Defines different types of alert sounds for alarms." .

### Alarm-based object properties
:lowAlertSound a :AlertSoundType ;
    rdfs:label "Low Alert Sound" .

:mediumAlertSound a :AlertSoundType ;
    rdfs:label "Medium Alert Sound" .

:highAlertSound a :AlertSoundType ;
    rdfs:label "High Alert Sound" .

:AlertPriorityLevel a owl:Class ;
    rdfs:subClassOf dev:AlertEntity ;
    rdfs:label "Alert Priority Level" ;
    rdfs:comment "Defines priority levels for alerts/alarms." .


:lowPriority a :AlertPriorityLevel ;
    :hasSoundEffect :lowAlertSound ;
    :hasColourEffect "Blue" ;
    rdfs:label "Low Priority alarm" .

:mediumPriority a :AlertPriorityLevel ;
    :hasSoundEffect :mediumAlertSound ;
    :hasColourEffect "Yellow" ;
    rdfs:label "Medium Priority alarm" .

:highPriority a :AlertPriorityLevel ;
    :hasSoundEffect :highAlertSound ;
    :hasColourEffect "Red" ;
    rdfs:label "High Priority alarm" .

:AlertTypeGroup a owl:Class ;
    rdfs:subClassOf dev:AlertEntity ;
    rdfs:label "Alert Type Group" ;
    rdfs:comment "Defines groups/categories for alerts/alarms." .

:technicalAlarmGroup a :AlertTypeGroup ;
    rdfs:label "Technical Alarm Group" .

:physiologicalAlarmGroup a :AlertTypeGroup ;
    rdfs:label "Physiological Alarm Group" .


@prefix : <http://example.org/cdo/device#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/cdo/device>
    a owl:Ontology ;
    rdfs:label "Device Ontology (structure)" .

:PhysicalDevice a owl:Class ; rdfs:subClassOf :DeviceEntity .
:FunctionalUnit a owl:Class ; rdfs:subClassOf :DeviceEntity .
:Sensor a owl:Class ; rdfs:subClassOf :DeviceEntity .
:Signal a owl:Class ; rdfs:subClassOf :DeviceEntity .
:Metric a owl:Class ; rdfs:subClassOf :DeviceEntity .

:hasFunctionalUnit a owl:ObjectProperty ;
    rdfs:domain :PhysicalDevice ;
    rdfs:range :FunctionalUnit .

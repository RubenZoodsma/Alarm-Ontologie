@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical#> .
@prefix common: <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/common#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .


#################################################################
# ONTOLOGY HEADER
#################################################################

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/clinical>
    a owl:Ontology ;
    rdfs:label "Alarm Ontology - Clinical Module" ;
    owl:imports <./alarmOnto_common.ttl> .


#################################################################
# CLINICAL-SIDE CLASSES
#################################################################

:ClinicalEntity a owl:Class ;
    rdfs:subClassOf common:Entity ;
    rdfs:label "Clinical Entity" .

:TherapeuticModality a owl:Class ;
    rdfs:subClassOf :ClinicalEntity ;
    rdfs:label "Therapeutic Modality" ;
    rdfs:comment "Intervention or treatment aimed at managing physiological conditions." .

:Patient a owl:Class ;
    rdfs:subClassOf :ClinicalEntity ;
    rdfs:label "Patient" ;
    rdfs:comment "The subject/organism for which device and clinical data apply." .

:PhysiologicalSystem a owl:Class ;
    rdfs:subClassOf :ClinicalEntity ;
    rdfs:label "Physiological System" ;
    rdfs:comment "System of organs that collectively maintain a physiological function (e.g. pulmonary system)." .

:Organ a owl:Class ;
    rdfs:subClassOf :ClinicalEntity ;
    rdfs:label "Organ" ;
    rdfs:comment "Anatomical/functional unit such as lung or heart." .

:PhysiologicalProcess a owl:Class ;
    rdfs:subClassOf :ClinicalEntity ;
    rdfs:label "Physiological Process" ;
    rdfs:comment "Process such as oxygenation, ventilation, perfusion." .

:PhysiologicalProperty a owl:Class ;
    rdfs:subClassOf :ClinicalEntity ;
    rdfs:subClassOf [ a owl:Restriction ;
                     owl:onProperty common:hasStateInstance ;
                     owl:someValuesFrom [ a owl:Class ;
                                        owl:oneOf ( common:Low common:High common:Normal common:Critical common:Unknown common:Missing ) ] ] ;
    rdfs:label "Physiological Property" ;
    rdfs:comment "Measurable property of a physiological process (e.g. SaO2, RR, PaO2). States are constrained to measurement-related values (Low, High, Normal, Critical, Unknown, Missing)." .


#################################################################
# OBJECT PROPERTIES (CLINICAL)
#################################################################

:hasPhysiologicalSystem a owl:ObjectProperty ;
    rdfs:domain :Patient ;
    rdfs:range :PhysiologicalSystem ;
    rdfs:label "has physiological system" .

:hasOrgan a owl:ObjectProperty ;
    rdfs:domain :PhysiologicalSystem ;
    rdfs:range :Organ ;
    rdfs:label "has organ" .

:partOfSystem a owl:ObjectProperty ;
    rdfs:domain :Organ ;
    rdfs:range :PhysiologicalSystem ;
    rdfs:label "part of system" .

:hasPhysiologicalProcess a owl:ObjectProperty ;
    rdfs:domain :Organ ;
    rdfs:range :PhysiologicalProcess ;
    rdfs:label "has physiological process" .

:partOfProcess a owl:ObjectProperty ;
    rdfs:domain :PhysiologicalProperty ;
    rdfs:range :PhysiologicalProcess ;
    rdfs:label "part of process" ;
    rdfs:comment "Links a PhysiologicalProperty to the PhysiologicalProcess it belongs to. Used as entry point for upward propagation of hasObservationState via property chain axioms." .

:hasObservationState a owl:ObjectProperty ;
    rdfs:domain :ClinicalEntity ;
    rdfs:range common:State ;
    rdfs:label "has observation state" ;
    rdfs:comment "Indicates whether a clinical entity (property, process, organ, system) is being actively monitored. Observation states (e.g. Monitored, NotMonitored) propagate upward through the clinical taxonomy via property chain axioms — if a process is monitored, the containing organ is also monitored." ;
    ## Chain 1: Property → Process
    ## If a PhysiologicalProperty has observationState X, the process it belongs to also has X.
    owl:propertyChainAxiom ( [ owl:inverseOf :partOfProcess ] :hasObservationState ) ;
    ## Chain 2: Process → Organ
    ## If a PhysiologicalProcess has observationState X, the organ hosting it also has X.
    owl:propertyChainAxiom ( :hasPhysiologicalProcess :hasObservationState ) ;
    ## Chain 3: Organ → System
    ## If an Organ has observationState X, the system it belongs to also has X.
    owl:propertyChainAxiom ( :hasOrgan :hasObservationState ) .

:hasFunctionalState a owl:ObjectProperty ;
    rdfs:domain common:Entity ;
    rdfs:range common:State ;
    rdfs:label "has functional state" ;
    rdfs:comment "Indicates the operational or health status of a clinical entity (e.g. Active, Insufficient, Unknown). Functional states are local and do not propagate upward through the taxonomy. Replaces the generic clin:hasState for all non-observation state assertions." .



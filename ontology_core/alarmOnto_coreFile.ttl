@prefix : <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# NOTE: This core file is designed for Protégé import resolution.
# For programmatic loading with RDFLib, load modules individually.

<https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/core>
    a owl:Ontology ;
    owl:versionIRI <https://github.com/RubenZoodsma/Alarm-Ontologie/ontology/core/v1> ;
    rdfs:label "Alarm Ontology Core (structure + instances)" ;
    rdfs:comment "Main ontology file that imports all structural modules and instance-level data for the Alarm Ontology. For Protégé: load this file. For Python/RDFLib: load individual modules." ;

    owl:imports
        # --- Core structure modules ---
        <./alarmOnto_common.ttl> ,
        <./alarmOnto_device.ttl> , 
        <./alarmOnto_clinical.ttl> ,

        # --- Clinical instance modules ---
        <../ontology_instances/clinical_instances/1_patient.ttl> ,
        <../ontology_instances/clinical_instances/2_physiologicalSystem.ttl> ,
        <../ontology_instances/clinical_instances/3_organ.ttl> ,
        <../ontology_instances/clinical_instances/4_physiologicalProcess.ttl> ,
        <../ontology_instances/clinical_instances/5_physiologicalProperty.ttl> ,

        # --- Device instance modules ---
        <../ontology_instances/device_instances/1_physicalDevice.ttl> ,
        <../ontology_instances/device_instances/2_sensorInterface.ttl> ,
        <../ontology_instances/device_instances/3_sensor.ttl> ,
        <../ontology_instances/device_instances/4_functionalUnit.ttl> ,
        <../ontology_instances/device_instances/5_deviceChannel.ttl> ,
        <../ontology_instances/device_instances/6_Metric.ttl> ,
        <../ontology_instances/device_instances/7_measurementProcess.ttl> ,
        <../ontology_instances/device_instances/8_signal.ttl> ,
        <../ontology_instances/device_instances/9_measurementSite.ttl> ,

        # --- Alarm instance modules ---
        <../ontology_instances/alarm_instances/1_ACD_MonitorAlarms.ttl> ,
        <../ontology_instances/alarm_instances/2_ACS_MonitorAlarms.ttl> ,
        <../ontology_instances/alarm_instances/3_Cond_MonitorAlarms.ttl> .

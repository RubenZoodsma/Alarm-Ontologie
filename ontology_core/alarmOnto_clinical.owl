@prefix : <http://example.org/cdo/clinical#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/cdo/clinical>
    a owl:Ontology ;
    rdfs:label "Clinical Ontology (structure)" .

:Patient a owl:Class .
:PhysiologicalSystem a owl:Class .
:Organ a owl:Class .
:PhysiologicalProcess a owl:Class .
:PhysiologicalProperty a owl:Class .
